---
import ClientRouter from 'astro/components/ClientRouter.astro';
import SEO from '../components/public/SEO.astro';
import Sidebar from '../components/public/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  includePersonSchema?: boolean;
  includeWebPageSchema?: boolean;
}

const {
  title = 'Edson Pedraza — Frontend Developer',
  description = 'Portfolio personal de Edson Pedraza. Frontend Developer especializado en crear experiencias web interactivas y memorables.',
  image,
  lang = 'es',
  includePersonSchema = false,
  includeWebPageSchema = false,
} = Astro.props;
---
<html lang={Astro.currentLocale ?? lang ?? 'es'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- FOUC prevention: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <SEO title={title} description={description} image={image} lang={lang} includePersonSchema={includePersonSchema} includeWebPageSchema={includeWebPageSchema} />
    <ClientRouter />
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Reading progress bar -->
    <div id="progress-bar" aria-hidden="true"></div>

    <!-- Page transition overlay — vertical columns that wipe scaleX like the Splash -->
    <div id="page-transition" aria-hidden="true">
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <span id="transition-label"></span>
    </div>

    <Sidebar />
    <main>
      <slot />
    </main>

    <script>
      import gsap from 'gsap';
      import { navigate } from 'astro:transitions/client';
      import {
        ScrollTrigger,
        createLenis,
        destroyLenis,
        killPageAnimations,
        exitAnimation,
        enterAnimation,
        heroEnterFromSplash,
        initPageAnimations,
      } from '../lib/animations';

      if (!(window as any).__appInitialized) {
        (window as any).__appInitialized = true;
        let isFirstLoad = true;
        let _isTransitioning = false;

        createLenis();

        document.addEventListener('astro:before-swap', (e) => {
          killPageAnimations();
          destroyLenis();
          if ((window as any).__splashDone) {
            const incoming = (e as any).newDocument as Document | undefined;
            const splashEl = incoming?.getElementById('splash-screen');
            if (splashEl) (splashEl as HTMLElement).style.display = 'none';
          }
        });

        document.addEventListener('astro:after-swap', () => {
          createLenis();
          const label = document.getElementById('transition-label');
          if (label) gsap.to(label, { opacity: 0, duration: 0.15 });
          // gsap.set is synchronous — covers the new page on THIS frame before any paint.
          // gsap.fromTo's "from" values only apply on the next tick, leaving a one-frame gap
          // where new .pt-blind elements sit at CSS default scaleX(0), causing a double-reveal flash.
          gsap.killTweensOf('.pt-blind');
          gsap.set('.pt-blind', { scaleX: 1, transformOrigin: 'right center' });
          gsap.to('.pt-blind', {
            scaleX: 0,
            stagger: 0.06,
            duration: 0.3,
            ease: 'power2.inOut',
            delay: 0.05,
            onComplete: () => {
              gsap.set('.pt-blind', { transformOrigin: 'left center' });
              _isTransitioning = false;
            },
          });
        });

        document.addEventListener('astro:page-load', () => {
          initPageAnimations();
          ScrollTrigger.refresh();

          // Hash scroll runs after refresh() so pinned-section positions are correct.
          // The blinds are still opening (~0.6s) so the jump is invisible.
          const hash = window.location.hash;
          if (hash) {
            const target = document.querySelector(hash) as HTMLElement | null;
            if (target) {
              const l = (window as any).lenis;
              if (l) l.scrollTo(target, { immediate: true });
              else window.scrollTo({ top: (target as HTMLElement).offsetTop });
            }
          }

          if (!isFirstLoad) {
            enterAnimation();
          } else {
            // Pre-hide hero elements while splash covers the screen — prevents 1-frame flash
            if (document.querySelector('.hero')) {
              gsap.set('.img-bg', { scale: 1.08, opacity: 0 });
              gsap.set('.img-fg', { x: 30, scale: 1.05, opacity: 0 });
              gsap.set('.title-inner', { y: '100%' });
              gsap.set('.sidebar', { opacity: 0, x: -20 });
              gsap.set('.header-name', { opacity: 0, y: -10 });
              gsap.set('.spotify-slot', { opacity: 0, scale: 0.95 });
            }
            window.addEventListener('splash:complete', () => {
              heroEnterFromSplash();
            }, { once: true });
          }
          isFirstLoad = false;
        });

        window.addEventListener('scroll', () => {
          const progressBar = document.getElementById('progress-bar');
          const scrolled = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
          if (progressBar) progressBar.style.transform = `scaleX(${Math.min(scrolled, 1)})`;
        }, { passive: true });

        function runNavTransition(href: string, label?: string) {
          if (_isTransitioning) return;
          _isTransitioning = true;
          // Safety reset if navigate() somehow never triggers after-swap
          setTimeout(() => { _isTransitioning = false; }, 5000);

          const labelEl = document.getElementById('transition-label');
          if (label && labelEl) {
            labelEl.textContent = label;
            gsap.to(labelEl, { opacity: 1, duration: 0.2, delay: 0.25 });
          }

          gsap.killTweensOf('.pt-blind');
          exitAnimation();

          // Cover completes first, THEN navigate — this runs entirely before
          // startViewTransition() is called, so the browser never pauses rendering
          // and the user always sees the cover animation play.
          gsap.set('.pt-blind', { transformOrigin: 'left center' });
          gsap.fromTo('.pt-blind',
            { scaleX: 0 },
            {
              scaleX: 1,
              stagger: 0.06,
              duration: 0.3,
              ease: 'power2.inOut',
              onComplete: () => navigate(href),
            }
          );
        }

        (window as any).__runNavTransition = runNavTransition;

        document.addEventListener('click', (e: MouseEvent) => {
          const link = (e.target as Element).closest<HTMLAnchorElement>('a[href]');
          if (!link) return;
          if (link.target === '_blank') return;
          if (link.hasAttribute('download')) return;

          const href = link.href;
          if (!href || href.startsWith('mailto:') || href.startsWith('tel:')) return;

          let url: URL;
          try { url = new URL(href); } catch { return; }
          if (url.origin !== window.location.origin) return;

          const normalizePathname = (p: string) => p.length > 1 && p.endsWith('/') ? p.slice(0, -1) : p;
          if (normalizePathname(url.pathname) === normalizePathname(window.location.pathname) && url.hash) {
            e.preventDefault();
            const target = document.querySelector(url.hash) as HTMLElement | null;
            if (target) {
              const l = (window as any).lenis;
              if (l) {
                // Lenis ignores scrollTo() when stopped/locked unless force:true — the splash
                // calls lenis.stop() and a lingering stopped state makes clicks do nothing.
                l.start();
                // Resolve an explicit numeric Y. Only the PINNED section (.projects-section) needs
                // its ScrollTrigger.start — while pinned it's position:fixed so its rect is unreliable.
                // We must filter by t.pin: other sections (e.g. .timeline) also have ScrollTriggers,
                // but with animation start values like 'top center' that are NOT the section top.
                const pin = ScrollTrigger.getAll().find((t) => t.trigger === target && t.pin);
                const y = pin ? pin.start : target.getBoundingClientRect().top + window.scrollY;
                l.scrollTo(y, { duration: 1.2, force: true });
              } else {
                target.scrollIntoView({ behavior: 'smooth' });
              }
            }
            return;
          }

          if (link.hasAttribute('data-logo-link') && url.pathname === window.location.pathname) {
            e.preventDefault();
            if ((window as any).lenis) {
              (window as any).lenis.scrollTo(0, { duration: 1.5 });
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
            return;
          }

          const dataLabel = link.getAttribute('data-transition-label') ?? undefined;
          const isLangSwitch = !dataLabel && !!link.closest('.lang-switcher');
          const switchLabel = isLangSwitch
            ? (href.includes('/en') ? 'EN' : 'ES')
            : undefined;
          const label = dataLabel ?? switchLabel;

          e.preventDefault();
          runNavTransition(href, label);
        });
      }

      // Page transition panel starts off-screen left (set via CSS transform: translateX(-100%))
    </script>

    <style is:global>
      #progress-bar {
        position: fixed;
        top: 0;
        left: 80px;
        right: 0;
        height: 2px;
        background: var(--accent);
        transform-origin: left;
        transform: scaleX(0);
        z-index: 9997;
        pointer-events: none;
      }
      @media (max-width: 768px) {
        #progress-bar { left: 0; top: 60px; }
      }

      #page-transition {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        pointer-events: none;
      }
      .pt-blind {
        flex: 1;
        height: 100%;
        background: var(--bg-primary);
        transform: scaleX(0);
        transform-origin: left center;
        will-change: transform;
      }
      #transition-label {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: clamp(3rem, 8vw, 6rem);
        font-weight: 100;
        color: var(--text-primary);
        opacity: 0;
        letter-spacing: 0.2em;
        pointer-events: none;
      }
    </style>
  </body>
</html>
