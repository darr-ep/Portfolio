---
import ClientRouter from 'astro/components/ClientRouter.astro';
import SEO from '../components/public/SEO.astro';
import Sidebar from '../components/public/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  includePersonSchema?: boolean;
  includeWebPageSchema?: boolean;
}

const {
  title = 'Edson Pedraza — Frontend Developer',
  description = 'Portfolio personal de Edson Pedraza. Frontend Developer especializado en crear experiencias web interactivas y memorables.',
  image,
  lang = 'es',
  includePersonSchema = false,
  includeWebPageSchema = false,
} = Astro.props;
---
<html lang={Astro.currentLocale ?? lang ?? 'es'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- FOUC prevention: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <SEO title={title} description={description} image={image} lang={lang} includePersonSchema={includePersonSchema} includeWebPageSchema={includeWebPageSchema} />
    <ClientRouter />
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Reading progress bar -->
    <div id="progress-bar" aria-hidden="true"></div>

    <!-- Page transition overlay — vertical columns that wipe scaleX like the Splash -->
    <div id="page-transition" aria-hidden="true">
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <span id="transition-label"></span>
    </div>

    <Sidebar />
    <main>
      <slot />
    </main>

    <script>
      import gsap from 'gsap';
      import { navigate } from 'astro:transitions/client';
      import {
        ScrollTrigger,
        createLenis,
        destroyLenis,
        killPageAnimations,
        exitAnimation,
        enterAnimation,
        heroEnterFromSplash,
        initPageAnimations,
      } from '../lib/animations';

      if (!(window as any).__appInitialized) {
        (window as any).__appInitialized = true;
        let isFirstLoad = true;

        // Holds a promise that resolves when the exit animation finishes.
        // astro:before-swap waits on it before swapping the DOM.
        let _animLock: Promise<void> | null = null;

        createLenis();

        document.addEventListener('astro:before-swap', (e) => {
          killPageAnimations();
          destroyLenis();
          if ((window as any).__splashDone) {
            const incoming = (e as any).newDocument as Document | undefined;
            const splashEl = incoming?.getElementById('splash-screen');
            if (splashEl) (splashEl as HTMLElement).style.display = 'none';
          }
          // If an exit animation is running, defer the DOM swap until it finishes.
          if (_animLock) {
            const originalSwap = (e as any).swap as () => void;
            const lock = _animLock;
            _animLock = null;
            (e as any).swap = async () => {
              await lock;
              originalSwap();
              // After swap the new .pt-blind elements inherit CSS scaleX:0.
              // Force them to covered (scaleX:1) before the browser paints so
              // astro:after-swap can animate them from 1→0 (the reveal).
              gsap.set('.pt-blind', { scaleX: 1 });
            };
          }
        });

        document.addEventListener('astro:after-swap', () => {
          createLenis();
          const label = document.getElementById('transition-label');
          if (label) gsap.to(label, { opacity: 0, duration: 0.15 });
          // Reveal: columns collapse right-to-left from right origin, staggered L→R
          gsap.set('.pt-blind', { transformOrigin: 'right center' });
          gsap.to('.pt-blind', {
            scaleX: 0,
            stagger: 0.06,
            duration: 0.3,
            ease: 'power2.inOut',
            delay: 0.05,
            onComplete: () => gsap.set('.pt-blind', { transformOrigin: 'left center' }),
          });
        });

        document.addEventListener('astro:page-load', () => {
          initPageAnimations();
          ScrollTrigger.refresh();

          if (!isFirstLoad) {
            enterAnimation();
          } else {
            // Pre-hide hero elements while splash covers the screen — prevents 1-frame flash
            if (document.querySelector('.hero')) {
              gsap.set('.img-bg', { scale: 1.08, opacity: 0 });
              gsap.set('.img-fg', { x: 30, scale: 1.05, opacity: 0 });
              gsap.set('.title-inner', { y: '100%' });
              gsap.set('.sidebar', { opacity: 0, x: -20 });
              gsap.set('.header-name', { opacity: 0, y: -10 });
              gsap.set('.spotify-slot', { opacity: 0, scale: 0.95 });
            }
            window.addEventListener('splash:complete', () => {
              heroEnterFromSplash();
            }, { once: true });
          }
          isFirstLoad = false;
        });

        window.addEventListener('scroll', () => {
          const progressBar = document.getElementById('progress-bar');
          const scrolled = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
          if (progressBar) progressBar.style.transform = `scaleX(${Math.min(scrolled, 1)})`;
        }, { passive: true });

        function runNavTransition(href: string, label?: string) {
          const labelEl = document.getElementById('transition-label');

          if (label && labelEl) {
            labelEl.textContent = label;
            // Label fades in once most columns are covering (~60% through the stagger)
            gsap.to(labelEl, { opacity: 1, duration: 0.2, delay: 0.25 });
          }

          exitAnimation();

          // Cover: columns expand from left origin, staggered L→R
          // Lock resolves when all columns are fully covering the screen.
          _animLock = new Promise<void>((resolve) => {
            gsap.set('.pt-blind', { transformOrigin: 'left center' });
            gsap.fromTo('.pt-blind',
              { scaleX: 0 },
              { scaleX: 1, stagger: 0.06, duration: 0.3, ease: 'power2.inOut', onComplete: resolve }
            );
          });

          navigate(href);
        }

        (window as any).__runNavTransition = runNavTransition;

        document.addEventListener('click', (e: MouseEvent) => {
          const link = (e.target as Element).closest<HTMLAnchorElement>('a[href]');
          if (!link) return;
          if (link.target === '_blank') return;
          if (link.hasAttribute('download')) return;

          const href = link.href;
          if (!href || href.startsWith('mailto:') || href.startsWith('tel:')) return;

          let url: URL;
          try { url = new URL(href); } catch { return; }
          if (url.origin !== window.location.origin) return;

          if (url.pathname === window.location.pathname && url.hash) return;

          if (link.hasAttribute('data-logo-link') && url.pathname === window.location.pathname) {
            e.preventDefault();
            if ((window as any).lenis) {
              (window as any).lenis.scrollTo(0, { duration: 1.5 });
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
            return;
          }

          const isLangSwitch = !!link.closest('.lang-switcher');
          const switchLabel = isLangSwitch
            ? (href.includes('/en') ? 'EN' : 'ES')
            : undefined;

          e.preventDefault();
          runNavTransition(href, switchLabel);
        });
      }

      // Page transition panel starts off-screen left (set via CSS transform: translateX(-100%))
    </script>

    <style is:global>
      #progress-bar {
        position: fixed;
        top: 0;
        left: 80px;
        right: 0;
        height: 2px;
        background: var(--accent);
        transform-origin: left;
        transform: scaleX(0);
        z-index: 9997;
        pointer-events: none;
      }
      @media (max-width: 768px) {
        #progress-bar { left: 0; top: 60px; }
      }

      #page-transition {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        pointer-events: none;
      }
      .pt-blind {
        flex: 1;
        height: 100%;
        background: var(--bg-primary);
        transform: scaleX(0);
        transform-origin: left center;
        will-change: transform;
      }
      #transition-label {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: clamp(3rem, 8vw, 6rem);
        font-weight: 100;
        color: var(--text-primary);
        opacity: 0;
        letter-spacing: 0.2em;
        pointer-events: none;
      }
    </style>
  </body>
</html>
