---
import { Font } from 'astro:assets';
import ClientRouter from 'astro/components/ClientRouter.astro';
import SEO from '../components/public/SEO.astro';
import Sidebar from '../components/public/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  schemas?: Record<string, unknown>[];
}

const {
  title = 'Edson Pedraza — Frontend Developer',
  description = 'Portfolio personal de Edson Pedraza. Frontend Developer especializado en crear experiencias web interactivas y memorables.',
  image,
  lang = 'es',
  schemas = [],
} = Astro.props;
---
<html lang={Astro.currentLocale ?? lang ?? 'es'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/Logo-Light.png" />
    <meta name="generator" content={Astro.generator} />
    <!-- Umami analytics — privacy-first, self-hosted on the VPS. Public site only (admin uses AdminLayout). -->
    <script defer src="https://analytics.edsonpedraza.com/script.js" data-website-id="c1b610d5-3b16-4cf7-b8c4-29279cb81367"></script>
    <!-- FOUC prevention: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <SEO title={title} description={description} image={image} lang={lang} url={Astro.url.pathname} schemas={schemas} />
    <!-- Self-hosted fonts (Astro Fonts API), replacing the Google Fonts @import FOUT. No `preload`:
         each font now ships many weights, and <Font preload> preloads ALL of them — most go unused
         on a given page (console warnings + wasted bytes). @font-face are inline + files are local,
         so the browser fetches just the weights each page renders. -->
    <Font cssVariable="--font-albert-sans" />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-outfit" />
    <Font cssVariable="--font-cormorant" />
    <ClientRouter />
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Reading progress bar -->
    <div id="progress-bar" aria-hidden="true"></div>

    <!-- Page transition overlay — vertical columns that wipe scaleX like the Splash -->
    <div id="page-transition" aria-hidden="true" transition:persist>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <span id="transition-label"></span>
      <div id="transition-logo" aria-hidden="true">
        <img src="/assets/Logo-Dark.webp" alt="" class="tl-logo tl-dark" />
        <img src="/assets/Logo-Light.webp" alt="" class="tl-logo tl-light" />
      </div>
    </div>

    <Sidebar />
    <main>
      <slot />
    </main>

    <script>
      import gsap from 'gsap';
      import { navigate } from 'astro:transitions/client';
      import {
        ScrollTrigger,
        createLenis,
        destroyLenis,
        killPageAnimations,
        enterAnimation,
        heroEnterFromSplash,
        initPageAnimations,
      } from '../lib/animations';

      if (!(window as any).__appInitialized) {
        (window as any).__appInitialized = true;
        let isFirstLoad = true;
        let _isTransitioning = false;
        // The in-flight navigation (click OR popstate), or null when idle / first load. Holds the
        // destination label and a resolver fired when astro:page-load signals the page is ready.
        let _nav: { label: string | null; useLogo: boolean; ready: () => void } | null = null;
        // Minimum time the screen stays covered, measured from the exit start. A near-instant
        // data load can't cut the exit short; the reveal waits out this floor. Tunable.
        const MIN_COVER_MS = 1000;
        // Destination cues keyed by normalized pathname, recorded on every forward navigation so
        // browser back/forward (popstate) can replay the SAME cue that first reached that page.
        const _pathLabels = new Map<string, { label: string | null; useLogo: boolean }>();
        const normalizePathname = (p: string) => (p.length > 1 && p.endsWith('/') ? p.slice(0, -1) : p);
        const isHomePath = (p: string) => p === '/' || p === '/en';

        // Set the cue's opacity INSTANTLY via GSAP — used across the swap to re-assert state on a
        // fresh (non-persisted) node without animating (which read as a flicker). The label/logo
        // fades are GSAP-driven now (same reliable ticker as the blinds); a CSS opacity transition
        // proved fragile — a main-thread stall at the transition's START skipped it and snapped the
        // cue straight to the end value (the "text disappears without fading" bug).
        function ptSet(el: Element | null, show: boolean) {
          if (!el) return;
          gsap.set(el, { opacity: show ? 1 : 0 });
        }

        createLenis();

        document.addEventListener('astro:before-swap', (e) => {
          killPageAnimations();
          destroyLenis();
          if ((window as any).__splashDone) {
            const incoming = (e as any).newDocument as Document | undefined;
            const splashEl = incoming?.getElementById('splash-screen');
            if (splashEl) (splashEl as HTMLElement).style.display = 'none';
          }
        });

        document.addEventListener('astro:after-swap', () => {
          createLenis();
          // Only OUR navigations cover the screen. Popstate (browser back/forward) never closed
          // the blinds, so leave them open and let the swap show instantly.
          if (!_nav) return;

          // Defensive + synchronous (after-swap runs before the browser paints the new page):
          // #page-transition uses transition:persist so the covered node SHOULD survive the swap,
          // but if it didn't, the incoming blinds/label are fresh — re-assert the covered state
          // and the label here so nothing flashes through, regardless of how persist resolved.
          gsap.set('.pt-blind', { scaleX: 1, transformOrigin: 'right center' });
          // Re-assert the cue INSTANTLY (ptSet, no transition). If the overlay node wasn't reused
          // across the swap, the fresh #transition-label starts hidden; animating it back in here
          // is exactly the flicker (visible → swap shows empty → fade in again). ptSet matches the
          // pre-swap visible state in one frame, so the swap is seamless.
          const label = document.getElementById('transition-label');
          const logo = document.getElementById('transition-logo');
          if (_nav.useLogo) {
            ptSet(label, false);
            ptSet(logo, true);
          } else if (_nav.label) {
            if (label) label.textContent = _nav.label;
            ptSet(label, true);
            ptSet(logo, false);
          } else {
            ptSet(label, false);
            ptSet(logo, false);
          }
        });

        document.addEventListener('astro:page-load', () => {
          // try/finally so a throw in section init can NEVER strand the reveal: _nav.ready() in
          // the finally always resolves pageReady, otherwise the page stays covered + label stuck.
          try {
          initPageAnimations();
          ScrollTrigger.refresh();

          // Hash scroll runs after refresh() so pinned-section positions are correct, and while
          // the blinds are still covering — the jump is invisible.
          const hash = window.location.hash;
          if (hash) {
            const target = document.querySelector(hash) as HTMLElement | null;
            if (target) {
              const l = (window as any).lenis;
              if (l) {
                // Lenis was just created in after-swap with no raf tick yet, so its internal `limit`
                // is still 0 — a plain scrollTo to a Y below the fold clamps to 0 and lands on the
                // hero. resize() measures the document first. start() + force defeat any stopped/
                // locked state (the documented Lenis gotcha). Compute Y the same robust way as the
                // same-page handler (pin.start for pinned sections, rect otherwise).
                l.start();
                l.resize();
                const pin = ScrollTrigger.getAll().find((t) => t.trigger === target && t.pin);
                const y = pin ? pin.start : target.getBoundingClientRect().top + window.scrollY;
                l.scrollTo(y, { immediate: true, force: true });
              } else {
                window.scrollTo({ top: (target as HTMLElement).offsetTop });
              }
            }
          }

          if (isFirstLoad) {
            // Pre-hide hero elements while splash covers the screen — prevents 1-frame flash
            if (document.querySelector('.hero')) {
              gsap.set('.img-bg', { scale: 1.08, opacity: 0 });
              gsap.set('.img-fg', { x: 30, scale: 1.05, opacity: 0 });
              gsap.set('.title-inner', { y: '100%' });
              gsap.set('.sidebar', { opacity: 0, x: -20 });
              gsap.set('.header-name', { opacity: 0, y: -10 });
              gsap.set('.spotify-slot', { opacity: 0, scale: 0.95 });
            }
            window.addEventListener('splash:complete', () => {
              heroEnterFromSplash();
            }, { once: true });
          }
          } finally {
            isFirstLoad = false;
            // Signal the in-flight navigation that the new page is swapped AND initialized. The
            // reveal (owned by runNavTransition) fires from here via Promise resolution.
            //
            // Gate the resolve so the reveal never opens onto a still-mounting page. Two problems
            // converge in the page-load frame: (a) it runs right after the heavy SYNCHRONOUS
            // initPageAnimations() + ScrollTrigger.refresh(), and (b) enterAnimation() immediately
            // tweens opacity/scale on the hero <img>s — if those aren't decoded yet, the first tick
            // DECODES them on the main thread (~230ms stall). Either stall eats the label's CSS fade
            // (it snaps to opacity 0 instead of fading) and the blinds' first frame (dead black gap).
            // So: wait for the above-the-fold hero images to decode, THEN two rAFs for a clean painted
            // frame, and only then resolve. img.decode() also waits out the download — the cover hides it.
            const ready = _nav?.ready;
            if (ready) {
              const imgs = Array.from(document.querySelectorAll<HTMLImageElement>('.hero-img'));
              const decode = (img: HTMLImageElement): Promise<unknown> => {
                try { return img.decode().catch(() => {}); } catch { return Promise.resolve(); }
              };
              Promise.all(imgs.map(decode)).then(() =>
                requestAnimationFrame(() => requestAnimationFrame(ready)));
            }
          }
        });

        window.addEventListener('scroll', () => {
          const progressBar = document.getElementById('progress-bar');
          const scrolled = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
          if (progressBar) progressBar.style.transform = `scaleX(${Math.min(scrolled, 1)})`;
        }, { passive: true });

        // EXIT: fade the destination cue in, fade non-hero content out, close the blinds. Resolves
        // when the cover is fully closed. It does NOT navigate — the caller decides what comes next
        // (runNavTransition navigates; the popstate loader wrapper lets ClientRouter swap).
        function playExitCover(label?: string | null, useLogo = false) {
          const labelEl = document.getElementById('transition-label');
          const logoEl = document.getElementById('transition-logo');
          gsap.killTweensOf('.pt-blind');

          return new Promise<void>((resolve) => {
            const exitTl = gsap.timeline({ onComplete: () => resolve() });
            // Fade in the destination cue (logo or text) with GSAP — same reliable ticker as the
            // blinds. ptSet gives a clean hidden start (opacity 0), then fade to 1 after ~0.1s as the
            // cover closes.
            if (useLogo && logoEl) {
              ptSet(labelEl, false);
              ptSet(logoEl, false);
              gsap.to(logoEl, { opacity: 1, duration: 0.2, delay: 0.1 });
            } else {
              ptSet(logoEl, false);
              if (labelEl) {
                if (label) {
                  labelEl.textContent = label;
                  ptSet(labelEl, false);
                  gsap.to(labelEl, { opacity: 1, duration: 0.2, delay: 0.1 });
                } else {
                  ptSet(labelEl, false);
                }
              }
            }
            // Non-hero pages get a subtle content fade before the columns cover them.
            if (!document.querySelector('.hero')) {
              exitTl.to('main > *', { opacity: 0, y: -20, duration: 0.22, ease: 'power2.in', stagger: 0.03, overwrite: true }, 0);
            }
            exitTl.set('.pt-blind', { transformOrigin: 'left center' }, 0);
            exitTl.fromTo('.pt-blind',
              { scaleX: 0 },
              { scaleX: 1, stagger: 0.06, duration: 0.3, ease: 'power2.inOut' }, 0);
          });
        }

        // REVEAL: one GSAP timeline owns the whole thing, so nothing rides the fragile CSS path and
        // enterAnimation can't share a frame with the fade. Fires only when BOTH the page is ready
        // (astro:page-load) AND the time floor has elapsed — whichever finishes last. (1) Fade the
        // cue out. (2) Only AFTER it has faded (0.25s) open the blinds + run enterAnimation, so
        // enter's heavy hero work can't jank the fade or the blinds' first frame.
        function scheduleReveal(pageReady: Promise<void>, minTime: Promise<void>, safetyId: number) {
          Promise.all([pageReady, minTime]).then(() => {
            clearTimeout(safetyId);
            const labelOut = document.getElementById('transition-label');
            const logoOut = document.getElementById('transition-logo');
            const cues = [labelOut, logoOut].filter((el): el is HTMLElement => !!el);

            const reveal = gsap.timeline({
              onComplete: () => {
                gsap.set('.pt-blind', { transformOrigin: 'left center' });
                gsap.ticker.lagSmoothing(0); // restore Lenis-friendly setting
                _isTransitioning = false;
                _nav = null;
              },
            });
            reveal.to(cues, { opacity: 0, duration: 0.25, ease: 'power1.out' }, 0);
            reveal.set('.pt-blind', { transformOrigin: 'right center' }, 0.25);
            reveal.to('.pt-blind', { scaleX: 0, stagger: 0.06, duration: 0.3, ease: 'power2.inOut' }, 0.25);
            reveal.add(enterAnimation(), 0.25);
          });
        }

        // Shared setup for any covered transition: cap lagSmoothing, build the pageReady/minTime
        // gate (pageReady's resolver lives on _nav, fired by astro:page-load), arm the safety
        // timeout, and schedule the reveal.
        //
        // animations.ts sets lagSmoothing(0) globally (for Lenis). That makes a single janky frame —
        // e.g. the destination's heavy page-load init + hero enter — get fully absorbed by GSAP on
        // the next tick, snapping the reveal to its end (label + blinds jump instead of fading). Cap
        // per-tick advance for the duration of the transition only.
        function beginCoveredTransition(label: string | null, useLogo: boolean) {
          gsap.ticker.lagSmoothing(100, 16);
          const pageReady = new Promise<void>((resolve) => {
            _nav = { label, useLogo, ready: resolve };
          });
          const minTime = new Promise<void>((resolve) => {
            gsap.delayedCall(MIN_COVER_MS / 1000, resolve);
          });
          // Safety: never strand the lock if navigation never completes.
          const safety = window.setTimeout(() => { gsap.ticker.lagSmoothing(0); _isTransitioning = false; _nav = null; }, 8000);
          scheduleReveal(pageReady, minTime, safety);
        }

        // Click-initiated navigation: cover, then navigate; the reveal plays after page-load.
        function runNavTransition(href: string, label?: string, useLogo = false) {
          if (_isTransitioning) return;
          _isTransitioning = true;

          // Record this destination's cue so a later back/forward to it replays the same transition.
          // Skip hash links: they share a pathname with the page itself (e.g. '/#servicios' → '/'),
          // and the popstate lookup matches on pathname only — recording them would clobber the home
          // entry (back to '/' would show 'SERVICIOS' instead of the logo).
          try {
            const dest = new URL(href);
            if (!dest.hash) _pathLabels.set(normalizePathname(dest.pathname), { label: label ?? null, useLogo });
          } catch { /* ignore malformed href */ }

          beginCoveredTransition(label ?? null, useLogo);
          playExitCover(label, useLogo).then(() => { navigate(href); });
        }

        // Browser back/forward: ClientRouter does NOT wait for us on traverse (unlike click, which we
        // preventDefault). So we hook the preparation phase — the only pre-swap hook on popstate —
        // and wrap its loader: close the blinds FIRST, then load under cover. The destination cue
        // comes from _pathLabels (recorded on the forward trip) or the logo for the home pages.
        document.addEventListener('astro:before-preparation', (event) => {
          const ev = event as any;
          if (ev.navigationType !== 'traverse') return; // back/forward only
          if (_isTransitioning) return; // our own click nav already owns the transition

          _isTransitioning = true;
          let destPath = '/';
          try { destPath = normalizePathname(new URL(ev.to, window.location.origin).pathname); } catch { /* keep default */ }
          const entry = _pathLabels.get(destPath);
          const useLogo = entry?.useLogo ?? isHomePath(destPath);
          const label = entry?.label ?? null;

          beginCoveredTransition(label, useLogo);

          const originalLoader = ev.loader;
          ev.loader = async () => {
            await playExitCover(label, useLogo);
            await originalLoader();
          };
        });

        (window as any).__runNavTransition = runNavTransition;

        document.addEventListener('click', (e: MouseEvent) => {
          const link = (e.target as Element).closest<HTMLAnchorElement>('a[href]');
          if (!link) return;
          // Projects accordion: the header is an <a> for SEO/SSR, but clicking it SELECTS the
          // project (swaps the 3D image + expands its details) rather than navigating. Its own
          // listener in initProjects handles selection; opening happens via the image or "See more".
          if (link.classList.contains('accordion-header')) return;
          if (link.target === '_blank') return;
          if (link.hasAttribute('download')) return;

          const href = link.href;
          if (!href || href.startsWith('mailto:') || href.startsWith('tel:')) return;

          let url: URL;
          try { url = new URL(href); } catch { return; }
          if (url.origin !== window.location.origin) return;

          if (normalizePathname(url.pathname) === normalizePathname(window.location.pathname) && url.hash) {
            e.preventDefault();
            const target = document.querySelector(url.hash) as HTMLElement | null;
            if (target) {
              const l = (window as any).lenis;
              if (l) {
                // Lenis ignores scrollTo() when stopped/locked unless force:true — the splash
                // calls lenis.stop() and a lingering stopped state makes clicks do nothing.
                l.start();
                // Resolve an explicit numeric Y. Only the PINNED section (.projects-section) needs
                // its ScrollTrigger.start — while pinned it's position:fixed so its rect is unreliable.
                // We must filter by t.pin: other sections (e.g. .timeline) also have ScrollTriggers,
                // but with animation start values like 'top center' that are NOT the section top.
                const pin = ScrollTrigger.getAll().find((t) => t.trigger === target && t.pin);
                const y = pin ? pin.start : target.getBoundingClientRect().top + window.scrollY;
                l.scrollTo(y, { duration: 1.2, force: true });
              } else {
                target.scrollIntoView({ behavior: 'smooth' });
              }
            }
            return;
          }

          if (link.hasAttribute('data-logo-link') && url.pathname === window.location.pathname) {
            e.preventDefault();
            if ((window as any).lenis) {
              (window as any).lenis.scrollTo(0, { duration: 1.5 });
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
            return;
          }

          // Logo navigating to a DIFFERENT page (return to landing): show the logotype instead
          // of text. (Same-page logo click is handled above as a scroll-to-top.)
          const isLogo = link.hasAttribute('data-logo-link');
          const dataLabel = link.getAttribute('data-transition-label') ?? undefined;
          const isLangSwitch = !dataLabel && !isLogo && !!link.closest('.lang-switcher');
          const switchLabel = isLangSwitch
            ? (href.includes('/en') ? 'EN' : 'ES')
            : undefined;
          const label = dataLabel ?? switchLabel;

          e.preventDefault();
          runNavTransition(href, label, isLogo);
        // Capture phase: run BEFORE Astro ClientRouter's own (bubbling) click listener so our
        // preventDefault() lands first. Otherwise ClientRouter swaps immediately on click — a
        // second navigation that races our cover (page shows through before the blinds close).
        }, true);
      }

      // Page transition panel starts off-screen left (set via CSS transform: translateX(-100%))
    </script>

    <style is:global>
      #progress-bar {
        position: fixed;
        top: 0;
        left: 80px;
        right: 0;
        height: 2px;
        background: var(--accent);
        transform-origin: left;
        transform: scaleX(0);
        z-index: 9997;
        pointer-events: none;
      }
      @media (max-width: 768px) {
        #progress-bar { left: 0; top: 0; }
      }

      #page-transition {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        pointer-events: none;
      }
      .pt-blind {
        flex: 1;
        height: 100%;
        background: var(--bg-primary);
        /* Same-colour 1px bleed seals sub-pixel seams between columns. */
        box-shadow: 0 0 0 1px var(--bg-primary);
        transform: scaleX(0);
        transform-origin: left center;
        will-change: transform;
      }
      #transition-label {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: clamp(1.8rem, 4vw, 4.2rem);
        font-weight: 100;
        color: var(--text-primary);
        opacity: 0;
        letter-spacing: 0.2em;
        pointer-events: none;
        /* opacity is driven by GSAP (see runNavTransition). No CSS transition here — GSAP's instant
           ptSet re-assert across the swap would otherwise re-trigger it and flicker. */
      }
      #transition-logo {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
      }
      /* A touch larger than the transition label. */
      #transition-logo .tl-logo {
        height: clamp(2.4rem, 5.5vw, 5.6rem);
        width: auto;
        display: block;
      }
      #transition-logo .tl-light { display: none; }
      html.light #transition-logo .tl-dark { display: none; }
      html.light #transition-logo .tl-light { display: block; }
    </style>
  </body>
</html>
