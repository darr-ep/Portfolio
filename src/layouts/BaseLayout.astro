---
import ClientRouter from 'astro/components/ClientRouter.astro';
import SEO from '../components/public/SEO.astro';
import Sidebar from '../components/public/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  includePersonSchema?: boolean;
  includeWebPageSchema?: boolean;
}

const {
  title = 'Edson Pedraza — Frontend Developer',
  description = 'Portfolio personal de Edson Pedraza. Frontend Developer especializado en crear experiencias web interactivas y memorables.',
  image,
  lang = 'es',
  includePersonSchema = false,
  includeWebPageSchema = false,
} = Astro.props;
---
<html lang={Astro.currentLocale ?? lang ?? 'es'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- FOUC prevention: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <SEO title={title} description={description} image={image} lang={lang} includePersonSchema={includePersonSchema} includeWebPageSchema={includeWebPageSchema} />
    <ClientRouter />
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Reading progress bar -->
    <div id="progress-bar" aria-hidden="true"></div>

    <!-- Page transition overlay — vertical columns that wipe scaleX like the Splash -->
    <div id="page-transition" aria-hidden="true" transition:persist>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <div class="pt-blind"></div>
      <span id="transition-label"></span>
      <div id="transition-logo" aria-hidden="true">
        <img src="/assets/Logo-Dark.png" alt="" class="tl-logo tl-dark" />
        <img src="/assets/Logo-Light.png" alt="" class="tl-logo tl-light" />
      </div>
    </div>

    <Sidebar />
    <main>
      <slot />
    </main>

    <script>
      import gsap from 'gsap';
      import { navigate } from 'astro:transitions/client';
      import {
        ScrollTrigger,
        createLenis,
        destroyLenis,
        killPageAnimations,
        enterAnimation,
        heroEnterFromSplash,
        initPageAnimations,
      } from '../lib/animations';

      if (!(window as any).__appInitialized) {
        (window as any).__appInitialized = true;
        let isFirstLoad = true;
        let _isTransitioning = false;
        // The in-flight navigation WE initiated, or null for popstate / first load. Holds the
        // destination label and a resolver fired when astro:page-load signals the page is ready.
        let _nav: { label: string | null; useLogo: boolean; ready: () => void } | null = null;
        // Minimum time the screen stays covered, measured from the exit start. A near-instant
        // data load can't cut the exit short; the reveal waits out this floor. Tunable.
        const MIN_COVER_MS = 1000;

        // Toggle the .pt-show class WITHOUT animating — used across the swap so re-asserting the
        // cue on a fresh (non-persisted) node doesn't re-trigger the CSS fade (which read as a
        // flicker). Disable the transition, flip the class, force reflow, then restore it.
        function ptSet(el: Element | null, show: boolean) {
          if (!el) return;
          const s = (el as HTMLElement).style;
          s.transition = 'none';
          el.classList.toggle('pt-show', show);
          void (el as HTMLElement).offsetWidth; // force the 'none' to apply before re-enabling
          s.transition = '';
        }

        createLenis();

        document.addEventListener('astro:before-swap', (e) => {
          killPageAnimations();
          destroyLenis();
          if ((window as any).__splashDone) {
            const incoming = (e as any).newDocument as Document | undefined;
            const splashEl = incoming?.getElementById('splash-screen');
            if (splashEl) (splashEl as HTMLElement).style.display = 'none';
          }
        });

        document.addEventListener('astro:after-swap', () => {
          createLenis();
          // Only OUR navigations cover the screen. Popstate (browser back/forward) never closed
          // the blinds, so leave them open and let the swap show instantly.
          if (!_nav) return;

          // Defensive + synchronous (after-swap runs before the browser paints the new page):
          // #page-transition uses transition:persist so the covered node SHOULD survive the swap,
          // but if it didn't, the incoming blinds/label are fresh — re-assert the covered state
          // and the label here so nothing flashes through, regardless of how persist resolved.
          gsap.set('.pt-blind', { scaleX: 1, transformOrigin: 'right center' });
          // Re-assert the cue INSTANTLY (ptSet, no transition). If the overlay node wasn't reused
          // across the swap, the fresh #transition-label starts hidden; animating it back in here
          // is exactly the flicker (visible → swap shows empty → fade in again). ptSet matches the
          // pre-swap visible state in one frame, so the swap is seamless.
          const label = document.getElementById('transition-label');
          const logo = document.getElementById('transition-logo');
          if (_nav.useLogo) {
            ptSet(label, false);
            ptSet(logo, true);
          } else if (_nav.label) {
            if (label) label.textContent = _nav.label;
            ptSet(label, true);
            ptSet(logo, false);
          } else {
            ptSet(label, false);
            ptSet(logo, false);
          }
        });

        document.addEventListener('astro:page-load', () => {
          // try/finally so a throw in section init can NEVER strand the reveal: _nav.ready() in
          // the finally always resolves pageReady, otherwise the page stays covered + label stuck.
          try {
          initPageAnimations();
          ScrollTrigger.refresh();

          // Hash scroll runs after refresh() so pinned-section positions are correct, and while
          // the blinds are still covering — the jump is invisible.
          const hash = window.location.hash;
          if (hash) {
            const target = document.querySelector(hash) as HTMLElement | null;
            if (target) {
              const l = (window as any).lenis;
              if (l) l.scrollTo(target, { immediate: true });
              else window.scrollTo({ top: (target as HTMLElement).offsetTop });
            }
          }

          if (isFirstLoad) {
            // Pre-hide hero elements while splash covers the screen — prevents 1-frame flash
            if (document.querySelector('.hero')) {
              gsap.set('.img-bg', { scale: 1.08, opacity: 0 });
              gsap.set('.img-fg', { x: 30, scale: 1.05, opacity: 0 });
              gsap.set('.title-inner', { y: '100%' });
              gsap.set('.sidebar', { opacity: 0, x: -20 });
              gsap.set('.header-name', { opacity: 0, y: -10 });
              gsap.set('.spotify-slot', { opacity: 0, scale: 0.95 });
            }
            window.addEventListener('splash:complete', () => {
              heroEnterFromSplash();
            }, { once: true });
          }
          } finally {
            isFirstLoad = false;
            // Signal the in-flight navigation that the new page is swapped AND initialized. The
            // reveal (owned by runNavTransition) fires from here via Promise resolution.
            _nav?.ready();
          }
        });

        window.addEventListener('scroll', () => {
          const progressBar = document.getElementById('progress-bar');
          const scrolled = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
          if (progressBar) progressBar.style.transform = `scaleX(${Math.min(scrolled, 1)})`;
        }, { passive: true });

        // One timeline owns the EXIT (label-in + content fade + blinds cover), one owns the
        // REVEAL (label-out + blinds open + hero enter). The reveal fires only when BOTH the page
        // is ready (astro:page-load) AND the time floor has elapsed — whichever finishes last.
        // Nothing visual is tied to Astro's swap timing, so fast/slow loads look identical.
        function runNavTransition(href: string, label?: string, useLogo = false) {
          if (_isTransitioning) return;
          _isTransitioning = true;

          // animations.ts sets lagSmoothing(0) globally (for Lenis). That makes a single janky
          // frame — e.g. the destination's heavy page-load init + hero enter — get fully absorbed
          // by GSAP on the next tick, snapping the reveal timeline to its end (label + blinds jump
          // instead of fading). Cap per-tick advance for the duration of the transition only.
          gsap.ticker.lagSmoothing(100, 16);

          const pageReady = new Promise<void>((resolve) => {
            _nav = { label: label ?? null, useLogo, ready: resolve };
          });
          const minTime = new Promise<void>((resolve) => {
            gsap.delayedCall(MIN_COVER_MS / 1000, resolve);
          });
          // Safety: never strand the lock if navigation never completes.
          const safety = setTimeout(() => { gsap.ticker.lagSmoothing(0); _isTransitioning = false; _nav = null; }, 8000);

          const labelEl = document.getElementById('transition-label');
          const logoEl = document.getElementById('transition-logo');
          gsap.killTweensOf('.pt-blind');

          // ── EXIT ──
          const exitTl = gsap.timeline({ onComplete: () => { navigate(href); } });
          // Fade in the destination cue (logo or text) via CSS class — compositor-driven, so a
          // heavy destination load can't snap it. ptSet guarantees a clean hidden start (no flicker
          // if it was left visible), then add .pt-show after ~0.1s to fade in as the cover closes.
          if (useLogo && logoEl) {
            ptSet(labelEl, false);
            ptSet(logoEl, false);
            setTimeout(() => logoEl.classList.add('pt-show'), 100);
          } else {
            ptSet(logoEl, false);
            if (labelEl) {
              if (label) {
                labelEl.textContent = label;
                ptSet(labelEl, false);
                setTimeout(() => labelEl.classList.add('pt-show'), 100);
              } else {
                ptSet(labelEl, false);
              }
            }
          }
          // Non-hero pages get a subtle content fade before the columns cover them.
          if (!document.querySelector('.hero')) {
            exitTl.to('main > *', { opacity: 0, y: -20, duration: 0.22, ease: 'power2.in', stagger: 0.03, overwrite: true }, 0);
          }
          exitTl.set('.pt-blind', { transformOrigin: 'left center' }, 0);
          exitTl.fromTo('.pt-blind',
            { scaleX: 0 },
            { scaleX: 1, stagger: 0.06, duration: 0.3, ease: 'power2.inOut' }, 0);

          // ── REVEAL ──
          Promise.all([pageReady, minTime]).then(() => {
            clearTimeout(safety);
            const reveal = gsap.timeline({
              onComplete: () => {
                gsap.set('.pt-blind', { transformOrigin: 'left center' });
                gsap.ticker.lagSmoothing(0); // restore Lenis-friendly setting
                _isTransitioning = false;
                _nav = null;
              },
            });
            // Fade the label/logo out via CSS class (compositor-driven, immune to the heavy
            // destination-init jank that was snapping the GSAP tween). Fires as the reveal starts;
            // removing pt-show from a hidden element is a no-op.
            document.getElementById('transition-label')?.classList.remove('pt-show');
            document.getElementById('transition-logo')?.classList.remove('pt-show');
            reveal.set('.pt-blind', { transformOrigin: 'right center' }, 0);
            reveal.to('.pt-blind', { scaleX: 0, stagger: 0.06, duration: 0.3, ease: 'power2.inOut' }, 0);
            reveal.add(enterAnimation(), 0);
          });
        }

        (window as any).__runNavTransition = runNavTransition;

        document.addEventListener('click', (e: MouseEvent) => {
          const link = (e.target as Element).closest<HTMLAnchorElement>('a[href]');
          if (!link) return;
          if (link.target === '_blank') return;
          if (link.hasAttribute('download')) return;

          const href = link.href;
          if (!href || href.startsWith('mailto:') || href.startsWith('tel:')) return;

          let url: URL;
          try { url = new URL(href); } catch { return; }
          if (url.origin !== window.location.origin) return;

          const normalizePathname = (p: string) => p.length > 1 && p.endsWith('/') ? p.slice(0, -1) : p;
          if (normalizePathname(url.pathname) === normalizePathname(window.location.pathname) && url.hash) {
            e.preventDefault();
            const target = document.querySelector(url.hash) as HTMLElement | null;
            if (target) {
              const l = (window as any).lenis;
              if (l) {
                // Lenis ignores scrollTo() when stopped/locked unless force:true — the splash
                // calls lenis.stop() and a lingering stopped state makes clicks do nothing.
                l.start();
                // Resolve an explicit numeric Y. Only the PINNED section (.projects-section) needs
                // its ScrollTrigger.start — while pinned it's position:fixed so its rect is unreliable.
                // We must filter by t.pin: other sections (e.g. .timeline) also have ScrollTriggers,
                // but with animation start values like 'top center' that are NOT the section top.
                const pin = ScrollTrigger.getAll().find((t) => t.trigger === target && t.pin);
                const y = pin ? pin.start : target.getBoundingClientRect().top + window.scrollY;
                l.scrollTo(y, { duration: 1.2, force: true });
              } else {
                target.scrollIntoView({ behavior: 'smooth' });
              }
            }
            return;
          }

          if (link.hasAttribute('data-logo-link') && url.pathname === window.location.pathname) {
            e.preventDefault();
            if ((window as any).lenis) {
              (window as any).lenis.scrollTo(0, { duration: 1.5 });
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
            return;
          }

          // Logo navigating to a DIFFERENT page (return to landing): show the logotype instead
          // of text. (Same-page logo click is handled above as a scroll-to-top.)
          const isLogo = link.hasAttribute('data-logo-link');
          const dataLabel = link.getAttribute('data-transition-label') ?? undefined;
          const isLangSwitch = !dataLabel && !isLogo && !!link.closest('.lang-switcher');
          const switchLabel = isLangSwitch
            ? (href.includes('/en') ? 'EN' : 'ES')
            : undefined;
          const label = dataLabel ?? switchLabel;

          e.preventDefault();
          runNavTransition(href, label, isLogo);
        // Capture phase: run BEFORE Astro ClientRouter's own (bubbling) click listener so our
        // preventDefault() lands first. Otherwise ClientRouter swaps immediately on click — a
        // second navigation that races our cover (page shows through before the blinds close).
        }, true);
      }

      // Page transition panel starts off-screen left (set via CSS transform: translateX(-100%))
    </script>

    <style is:global>
      #progress-bar {
        position: fixed;
        top: 0;
        left: 80px;
        right: 0;
        height: 2px;
        background: var(--accent);
        transform-origin: left;
        transform: scaleX(0);
        z-index: 9997;
        pointer-events: none;
      }
      @media (max-width: 768px) {
        #progress-bar { left: 0; top: 60px; }
      }

      #page-transition {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        pointer-events: none;
      }
      .pt-blind {
        flex: 1;
        height: 100%;
        background: var(--bg-primary);
        transform: scaleX(0);
        transform-origin: left center;
        will-change: transform;
      }
      #transition-label {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: clamp(1.8rem, 4vw, 4.2rem);
        font-weight: 100;
        color: var(--text-primary);
        opacity: 0;
        letter-spacing: 0.2em;
        pointer-events: none;
        /* Compositor-driven fade — immune to main-thread jank during heavy page-load init,
           which would otherwise let a GSAP opacity tween snap to its end. */
        transition: opacity 0.2s ease;
      }
      #transition-logo {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
      }
      #transition-label.pt-show,
      #transition-logo.pt-show { opacity: 1; }
      /* A touch larger than the transition label. */
      #transition-logo .tl-logo {
        height: clamp(2.4rem, 5.5vw, 5.6rem);
        width: auto;
        display: block;
      }
      #transition-logo .tl-light { display: none; }
      html.light #transition-logo .tl-dark { display: none; }
      html.light #transition-logo .tl-light { display: block; }
    </style>
  </body>
</html>
