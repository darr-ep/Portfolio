---
import ClientRouter from 'astro/components/ClientRouter.astro';
import SEO from '../components/public/SEO.astro';
import Sidebar from '../components/public/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
}

const {
  title = 'Edson Pedraza — Frontend Developer',
  description = 'Portfolio personal de Edson Pedraza. Frontend Developer especializado en crear experiencias web interactivas y memorables.',
  image,
  lang = 'es',
} = Astro.props;
---
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- FOUC prevention: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <SEO title={title} description={description} image={image} lang={lang} />
    <ClientRouter />
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Reading progress bar -->
    <div id="progress-bar" aria-hidden="true"></div>

    <!-- Language transition overlay (mini venetian blinds) -->
    <div id="lang-transition" aria-hidden="true">
      <div class="lang-blind"></div>
      <div class="lang-blind"></div>
      <div class="lang-blind"></div>
      <div class="lang-blind"></div>
      <span id="lang-transition-label"></span>
    </div>

    <Sidebar lang={lang} />
    <main>
      <slot />
    </main>

    <script>
      import gsap from 'gsap';
      import ScrollTrigger from 'gsap/ScrollTrigger';
      import CustomEase from 'gsap/CustomEase';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger, CustomEase);

      let lenis: Lenis | null = null;

      function initLenis() {
        lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });

        function raf(time: number) {
          lenis!.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        lenis.on('scroll', ScrollTrigger.update);

        ScrollTrigger.scrollerProxy(document.body, {
          scrollTop(value?: number) {
            if (arguments.length && lenis && value !== undefined) {
              lenis.scrollTo(value);
            }
            return window.scrollY;
          },
          getBoundingClientRect() {
            return {
              top: 0,
              left: 0,
              width: window.innerWidth,
              height: window.innerHeight,
            };
          },
        });

        // Expose globally so Splash and other components can pause scroll
        (window as unknown as Record<string, unknown>).lenis = lenis;
      }

      document.addEventListener('astro:before-swap', () => {
        ScrollTrigger.getAll().forEach((st) => st.kill());
        lenis?.stop();
      });

      document.addEventListener('astro:after-swap', () => {
        lenis?.start();
        ScrollTrigger.refresh();
      });

      // Initial page load
      initLenis();

      // Reading progress bar
      const progressBar = document.getElementById('progress-bar');
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
        if (progressBar) progressBar.style.transform = `scaleX(${Math.min(scrolled, 1)})`;
      }, { passive: true });

      // Disable default View Transitions crossfade — our venetian blinds handle all transitions
      const styleEl = document.createElement('style');
      styleEl.textContent = `
        ::view-transition-old(root), ::view-transition-new(root) {
          animation: none !important;
          mix-blend-mode: normal !important;
        }
      `;
      document.head.appendChild(styleEl);

      // Venetian blinds init — always start closed (hidden)
      const langBlinds = document.querySelectorAll<HTMLElement>('.lang-blind');
      gsap.set(langBlinds, { scaleY: 0 });

      // After every ClientRouter navigation: open the blinds
      document.addEventListener('astro:after-swap', () => {
        const blinds = document.querySelectorAll<HTMLElement>('.lang-blind');
        const label = document.getElementById('lang-transition-label');
        gsap.to(blinds, { scaleY: 0, stagger: 0.06, duration: 0.3, ease: 'power2.inOut', delay: 0.05 });
        if (label) gsap.to(label, { opacity: 0, duration: 0.15 });
      });

      // Global navigation interceptor — venetian blinds for ALL internal links
      async function runNavTransition(href: string, label?: string) {
        const blinds = document.querySelectorAll<HTMLElement>('.lang-blind');
        const labelEl = document.getElementById('lang-transition-label');

        if (label && labelEl) {
          labelEl.textContent = label;
          gsap.to(labelEl, { opacity: 1, duration: 0.2, delay: 0.1 });
        }

        await new Promise<void>((resolve) => {
          gsap.to(blinds, {
            scaleY: 1,
            stagger: 0.06,
            duration: 0.25,
            ease: 'power2.inOut',
            onComplete: resolve,
          });
        });

        // Use Astro's navigate() so ClientRouter handles the page swap (no full reload)
        const { navigate } = await import('astro:transitions/client');
        await navigate(href);
      }

      document.addEventListener('click', (e: MouseEvent) => {
        const link = (e.target as Element).closest<HTMLAnchorElement>('a[href]');
        if (!link) return;

        // Skip external, _blank, download
        if (link.target === '_blank') return;
        if (link.hasAttribute('download')) return;

        const href = link.href;
        if (!href || href.startsWith('mailto:') || href.startsWith('tel:')) return;

        let url: URL;
        try { url = new URL(href); } catch { return; }
        if (url.origin !== window.location.origin) return;

        // Pure same-page hash (no path change) → let Lenis handle smooth scroll
        if (url.pathname === window.location.pathname && url.hash) return;

        // Check if it's a lang switcher link
        const isLangSwitch = !!link.closest('.lang-switcher');
        const switchLabel = isLangSwitch
          ? (href.includes('/en') ? 'EN' : 'ES')
          : undefined;

        e.preventDefault();
        runNavTransition(href, switchLabel);
      });
    </script>

    <style is:global>
      #progress-bar {
        position: fixed;
        top: 0;
        left: 80px;
        right: 0;
        height: 2px;
        background: var(--accent);
        transform-origin: left;
        transform: scaleX(0);
        z-index: 9997;
        pointer-events: none;
      }
      @media (max-width: 768px) {
        #progress-bar { left: 0; top: 60px; }
      }

      #lang-transition {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        pointer-events: none;
      }
      .lang-blind {
        flex: 1;
        background: var(--bg-primary);
        transform: scaleY(0);
        transform-origin: top;
        will-change: transform;
      }
      .lang-blind:nth-child(even) { transform-origin: bottom; }
      #lang-transition-label {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: clamp(3rem, 8vw, 6rem);
        font-weight: 100;
        color: var(--text-primary);
        opacity: 0;
        letter-spacing: 0.2em;
        pointer-events: none;
      }
    </style>
  </body>
</html>
