---
import { Font } from 'astro:assets';
import ClientRouter from 'astro/components/ClientRouter.astro';
import PixelBlast from '../components/islands/PixelBlast.tsx';
import '../styles/global.css';
import '../styles/admin-components.css';

// Props contract — kept identical to the old layout for backward compatibility.
interface Props {
  title?: string;
}
const { title = 'Admin — Portfolio CMS' } = Astro.props;

// Active-state helper: exact match for the root dashboard, prefix match for sections.
const pathname = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/admin') return pathname === '/admin';
  return pathname === href || pathname.startsWith(href + '/');
}
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/Logo-Light.png" />
    <!-- Admin pages must never be indexed. -->
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>

    <!-- FOUC prevention: apply stored theme before first paint (mirrors BaseLayout). -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') document.documentElement.classList.add('light');
      })();
    </script>

    <!-- Self-hosted fonts via Astro Fonts API (same family/weights as BaseLayout). -->
    <Font cssVariable="--font-albert-sans" />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-outfit" />
    <Font cssVariable="--font-cormorant" />

    <!-- SPA nav within admin pages (simple fade, not the public blinds/cover system). -->
    <ClientRouter />
  </head>
  <body>
    <!-- Decorative noise texture — same as the public site for visual continuity. -->
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- PixelBlast animated background (admin-tuned: low density, slow, no ripples). -->
    <div class="admin-pixel-bg" aria-hidden="true">
      <PixelBlast
        client:only="react"
        color="#e3a857"
        pixelSize={7}
        speed={0.1}
        patternDensity={0.22}
        patternScale={1.2}
        enableRipples={false}
        edgeFade={0.75}
        transparent={true}
        style={{ width: '100%', height: '100%' }}
      />
    </div>

    <!-- Sidebar -->
    <aside class="admin-sidebar" aria-label="Admin navigation">

      <!-- Brand -->
      <div class="sidebar-brand">
        <a href="/admin" class="brand-link" aria-label="Go to dashboard">
          <span class="brand-monogram" aria-hidden="true">EP</span>
        </a>
        <span class="brand-label">Admin</span>
      </div>

      <!-- Primary navigation -->
      <nav class="sidebar-nav" aria-label="Admin sections">

        <!-- Dashboard (top-level, no group) -->
        <a
          href="/admin"
          class:list={['nav-link', { active: pathname === '/admin' }]}
          aria-current={pathname === '/admin' ? 'page' : undefined}
        >
          <!-- Lucide: layout-dashboard -->
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="7" height="9" x="3" y="3" rx="1"/>
            <rect width="7" height="5" x="14" y="3" rx="1"/>
            <rect width="7" height="9" x="14" y="12" rx="1"/>
            <rect width="7" height="5" x="3" y="16" rx="1"/>
          </svg>
          <span>Dashboard</span>
        </a>

        <!-- Content group -->
        <div class="nav-group">
          <span class="nav-group-label">Content</span>

          <a
            href="/admin/projects"
            class:list={['nav-link', { active: isActive('/admin/projects') }]}
            aria-current={isActive('/admin/projects') ? 'page' : undefined}
          >
            <!-- Lucide: folder -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
            </svg>
            <span>Projects</span>
          </a>

          <a
            href="/admin/timeline"
            class:list={['nav-link', { active: isActive('/admin/timeline') }]}
            aria-current={isActive('/admin/timeline') ? 'page' : undefined}
          >
            <!-- Lucide: history -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
              <path d="M12 7v5l4 2"/>
            </svg>
            <span>Timeline</span>
          </a>

          <a
            href="/admin/technologies"
            class:list={['nav-link', { active: isActive('/admin/technologies') }]}
            aria-current={isActive('/admin/technologies') ? 'page' : undefined}
          >
            <!-- Lucide: monitor -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8m-4-4v4"/>
            </svg>
            <span>Technologies</span>
          </a>

          <a
            href="/admin/education"
            class:list={['nav-link', { active: isActive('/admin/education') }]}
            aria-current={isActive('/admin/education') ? 'page' : undefined}
          >
            <!-- Lucide: graduation-cap -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
              <path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
            <span>Education</span>
          </a>

          <a
            href="/admin/languages"
            class:list={['nav-link', { active: isActive('/admin/languages') }]}
            aria-current={isActive('/admin/languages') ? 'page' : undefined}
          >
            <!-- Lucide: globe -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
            <span>Languages</span>
          </a>
        </div>

        <!-- Account group -->
        <div class="nav-group">
          <span class="nav-group-label">Account</span>

          <a
            href="/admin/profile"
            class:list={['nav-link', { active: isActive('/admin/profile') }]}
            aria-current={isActive('/admin/profile') ? 'page' : undefined}
          >
            <!-- Lucide: user-round -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="8" r="5"/>
              <path d="M20 21a8 8 0 1 0-16 0"/>
            </svg>
            <span>Profile</span>
          </a>
        </div>
      </nav>

      <!-- Footer: site link + sign-out -->
      <div class="sidebar-footer">
        <a
          href="/"
          class="nav-link nav-link-secondary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open public site in new tab"
        >
          <!-- Lucide: external-link -->
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 3h6v6"/>
            <path d="M10 14 21 3"/>
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          </svg>
          <span>View site</span>
        </a>

        <form action="/admin/auth/logout" method="POST" class="logout-form">
          <button type="submit" class="nav-link nav-link-danger">
            <!-- Lucide: log-out -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" x2="9" y1="12" y2="12"/>
            </svg>
            <span>Sign out</span>
          </button>
        </form>
      </div>
    </aside>

    <!-- Main content -->
    <main class="admin-main" transition:animate="fade">
      <slot />
    </main>
  </body>
</html>

<style>
  /* ── Admin design-system tokens ───────────────────────────────────────────
     Names are kept for backward compatibility with existing admin pages that
     reference var(--admin-*). Values delegate to the global landing palette so
     light/dark theme changes propagate automatically.
     ----------------------------------------------------------------------- */
  :root {
    --admin-bg:      var(--bg-primary);    /* page background          */
    --admin-sidebar: var(--bg-primary);    /* sidebar background       */
    --admin-surface: var(--bg-secondary);  /* card/panel surface       */
    --admin-border:  var(--border-color);  /* dividers & outlines      */
    --admin-text:    var(--text-primary);  /* primary body text        */
    --admin-muted:   var(--text-muted);    /* secondary/hint text      */
    --admin-accent:  var(--accent);        /* highlight / active color */

    /* Layout geometry — override with CSS if a page needs a different width. */
    --admin-sidebar-width:     220px;
    --admin-sidebar-item-h:    36px;
    --admin-main-padding-x:    44px;
    --admin-main-padding-y:    36px;
  }

  /* ── PixelBlast background ────────────────────────────────────────────── */
  .admin-pixel-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none; /* NEVER intercept clicks — this is a decorative layer */
    opacity: 0.05;        /* Very subtle: 5% so it doesn't distract from forms   */
  }

  /* Kill the background for users who prefer reduced motion or on mobile where
     Three.js is an unnecessary GPU cost. */
  @media (prefers-reduced-motion: reduce) {
    .admin-pixel-bg { display: none; }
  }
  @media (max-width: 768px) {
    .admin-pixel-bg { display: none; }
  }

  /* ── Body shell ───────────────────────────────────────────────────────── */
  body {
    display: flex;
    min-height: 100vh;
    background: var(--admin-bg);
    color: var(--admin-text);
    font-family: var(--font-body);
  }

  /* ── Sidebar ──────────────────────────────────────────────────────────── */
  .admin-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--admin-sidebar-width);
    height: 100vh;
    background: var(--admin-sidebar);
    border-right: 1px solid var(--admin-border);
    display: flex;
    flex-direction: column;
    z-index: 100;
    overflow-y: auto;
    overflow-x: hidden;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  /* Brand area */
  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 20px 16px;
    border-bottom: 1px solid var(--admin-border);
    flex-shrink: 0;
  }

  .brand-link {
    text-decoration: none;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .brand-monogram {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(227, 168, 87, 0.10);
    border: 1px solid rgba(227, 168, 87, 0.20);
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    color: var(--admin-accent);
    letter-spacing: -0.5px;
    line-height: 1;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .brand-link:hover .brand-monogram {
    background: rgba(227, 168, 87, 0.18);
    border-color: rgba(227, 168, 87, 0.40);
  }

  .brand-label {
    font-family: var(--font-ui);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--admin-muted);
    user-select: none;
  }

  /* Navigation */
  .sidebar-nav {
    flex: 1;
    padding: 10px 0;
    display: flex;
    flex-direction: column;
  }

  .nav-group {
    padding: 8px 0 2px;
  }

  .nav-group + .nav-group {
    border-top: 1px solid var(--admin-border);
    margin-top: 6px;
  }

  .nav-group-label {
    display: block;
    font-family: var(--font-ui);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--admin-muted);
    opacity: 0.65;
    padding: 2px 16px 6px;
    user-select: none;
  }

  /* Shared styles for both <a> and <button> nav items */
  .nav-link {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 0 16px;
    height: var(--admin-sidebar-item-h);
    color: var(--text-secondary);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    border-left: 2px solid transparent;
    /* Reset button defaults */
    border-right: 0;
    border-top: 0;
    border-bottom: 0;
    background: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .nav-link svg {
    flex-shrink: 0;
    opacity: 0.8;
    transition: opacity 0.15s ease;
  }

  .nav-link:hover {
    color: var(--admin-text);
    background: rgba(255, 255, 255, 0.04);
  }

  html.light .nav-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .nav-link:hover svg {
    opacity: 1;
  }

  /* Active state — accent left border + subtle background tint */
  .nav-link.active {
    color: var(--admin-accent);
    border-left-color: var(--admin-accent);
    background: rgba(227, 168, 87, 0.07);
    font-weight: 500;
  }

  .nav-link.active svg {
    opacity: 1;
  }

  /* Modifier: secondary (muted, no active state) */
  .nav-link-secondary {
    color: var(--admin-muted);
  }

  /* Modifier: danger (sign-out) */
  .nav-link-danger {
    color: var(--admin-muted);
  }

  .nav-link-danger:hover {
    color: var(--danger, #ef4444);
    background: rgba(239, 68, 68, 0.07);
    border-left-color: transparent;
  }

  /* Footer section */
  .sidebar-footer {
    padding: 8px 0;
    border-top: 1px solid var(--admin-border);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
  }

  .logout-form {
    width: 100%;
  }

  /* ── Main content area ────────────────────────────────────────────────── */
  .admin-main {
    margin-left: var(--admin-sidebar-width);
    flex: 1;
    min-height: 100vh;
    padding: var(--admin-main-padding-y) var(--admin-main-padding-x);
    min-width: 0; /* prevents flex children from overflowing */
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  /* Medium screens: slim the sidebar to icon-only */
  @media (max-width: 900px) {
    :root {
      --admin-sidebar-width: 56px;
      --admin-main-padding-x: 20px;
      --admin-main-padding-y: 24px;
    }

    .brand-label,
    .nav-link span,
    .nav-group-label {
      display: none;
    }

    .sidebar-brand {
      justify-content: center;
      padding: 16px 0;
    }

    .nav-link {
      justify-content: center;
      padding: 0;
      border-left-color: transparent !important;
    }

    /* Restore accent indicator as a bottom border for icon-only mode */
    .nav-link.active {
      background: rgba(227, 168, 87, 0.10);
    }
  }
</style>
