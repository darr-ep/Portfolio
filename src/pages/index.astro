---
import BaseLayout from '../layouts/BaseLayout.astro';
import Splash from '../components/public/Splash.astro';
import Hero from '../components/public/Hero.astro';
import Marquee from '../components/public/Marquee.astro';
import Services from '../components/public/Services.astro';
import Projects from '../components/public/Projects.astro';
import Timeline from '../components/public/Timeline.astro';
import Details from '../components/public/Details.astro';
import Contact from '../components/public/Contact.astro';
---
<BaseLayout lang="es" includePersonSchema={true} includeWebPageSchema={true}>
  <Splash />
  <Hero />
  <Marquee />
  <Services />
  <Projects />
  <Timeline />
  <Details />
  <Contact />
</BaseLayout>
