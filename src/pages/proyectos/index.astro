---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectsIndex from '../../components/public/ProjectsIndex.astro';
import { buildWebPageSchema, absoluteUrl } from '../../lib/schema';

export const prerender = false;

const schemas = [
  buildWebPageSchema({
    type: 'CollectionPage',
    url: absoluteUrl('/proyectos'),
    name: 'Proyectos — Edson Pedraza',
    description: 'Proyectos y casos seleccionados de Edson Pedraza.',
  }),
];
---

<BaseLayout
  title="Proyectos — Edson Pedraza"
  description="Proyectos y casos seleccionados de Edson Pedraza."
  lang="es"
  schemas={schemas}
>
  <ProjectsIndex lang="es" />
</BaseLayout>
