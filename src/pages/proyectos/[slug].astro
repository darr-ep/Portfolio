---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import type { Project, ProjectImage } from '../../types/database';
import { getReadyNeighbors, getRelatedProjects } from '../../lib/projects';

export const prerender = false;

const { slug } = Astro.params;

const [detail, list] = await Promise.all([
  supabase.from('projects').select('*, project_images(*)').eq('slug', slug).single(),
  supabase.from('projects').select('*, project_images(slot_key, url)').order('sort_order', { ascending: true }),
]);

if (!detail.data || detail.error) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const project = detail.data as Project & { project_images: ProjectImage[] };
const images = project.project_images ?? [];
const imgBySlot = Object.fromEntries(images.map((i) => [i.slot_key, i])) as Record<string, ProjectImage | undefined>;

const title       = project.title_es       ?? project.title_en;
const category    = project.category_es     ?? project.category_en;
const description = project.description_es  ?? project.description_en;
const tagline     = project.tagline_es      ?? project.tagline_en      ?? null;
const role        = project.role_es         ?? project.role_en         ?? null;
const approachBody  = project.approach_body_es  ?? project.approach_body_en  ?? null;
const conclusion    = project.conclusion_es     ?? project.conclusion_en     ?? null;

const heroImg         = imgBySlot['hero'];
const mockupMain      = imgBySlot['mockup_main'];
const mockupSecondary = imgBySlot['mockup_secondary'];
const detailImg       = imgBySlot['detail'];
const ogImage = heroImg?.url ?? project.main_image ?? undefined;

const specs = [
  role && { label: 'Rol', value: role },
  project.collaborators && { label: 'Colaboración', value: project.collaborators },
  project.year && { label: 'Año', value: String(project.year) },
].filter(Boolean) as { label: string; value: string }[];

const allProjects = (list.data ?? []) as (Project & { project_images?: { slot_key: string; url: string }[] })[];
const { prev, next } = getReadyNeighbors(allProjects, project.slug, 'es');
const related = getRelatedProjects(allProjects, project.slug, 'es', 2);
---

<BaseLayout title={`${title} — Edson Pedraza`} description={description} image={ogImage} lang="es" includeWebPageSchema={true}>
  <article class="pd">

    <!-- First screen: hero fills the space above the spec sheet; both fit one viewport -->
    <div class="pd-top">
    <header class="pd-hero">
      {heroImg && <img src={heroImg.url} alt={heroImg.alt_es ?? title} class="pd-hero__img" crossorigin="anonymous" />}
      <div class="pd-hero__scrim"></div>
      <a href="/proyectos" class="pd-hero__back" data-transition-label="PROYECTOS">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver a proyectos
      </a>
      <div class="pd-hero__content">
        <span class="pd-badge">{category}</span>
        <h1 class="pd-title">{title}</h1>
        {tagline && <p class="pd-tagline">{tagline}</p>}
        {(project.live_url || project.github_url) && (
          <div class="pd-actions">
            {project.live_url && (
              <a href={project.live_url} class="pd-btn pd-btn--primary" target="_blank" rel="noopener noreferrer">Ver proyecto</a>
            )}
            {project.github_url && (
              <a href={project.github_url} class="pd-btn pd-btn--ghost" target="_blank" rel="noopener noreferrer">GitHub</a>
            )}
          </div>
        )}
      </div>
    </header>

    <!-- SPEC SHEET -->
    {(specs.length > 0 || (project.tech && project.tech.length > 0)) && (
      <section class="pd-specs">
        {specs.map((s) => (
          <div class="pd-spec">
            <span class="pd-spec__label">{s.label}</span>
            <span class="pd-spec__value">{s.value}</span>
          </div>
        ))}
        {project.tech && project.tech.length > 0 && (
          <div class="pd-spec pd-spec--stack">
            <span class="pd-spec__label">Stack</span>
            <div class="pd-tags">
              {project.tech.map((t: string) => <span class="pd-tag">{t}</span>)}
            </div>
          </div>
        )}
      </section>
    )}
    </div>

    <!-- Lead description -->
    {description && (
      <section class="pd-block">
        <p class="pd-lead">{description}</p>
      </section>
    )}

    <!-- INTERLEAVED — approach + main mockup -->
    {(approachBody || mockupMain) && (
      <section class="pd-row">
        {approachBody && (
          <div class="pd-row__text">
            <p class="pd-body">{approachBody}</p>
          </div>
        )}
        {mockupMain && (
          <div class="pd-row__media">
            <img src={mockupMain.url} alt={mockupMain.alt_es ?? `${title} mockup`} class="pd-figure" />
          </div>
        )}
      </section>
    )}

    <!-- INTERLEAVED (reversed) — secondary mockup + conclusion -->
    {(conclusion || mockupSecondary) && (
      <section class="pd-row pd-row--reverse">
        {conclusion && (
          <div class="pd-row__text">
            <h2 class="pd-h2">Resultado</h2>
            <p class="pd-body">{conclusion}</p>
          </div>
        )}
        {mockupSecondary && (
          <div class="pd-row__media">
            <img src={mockupSecondary.url} alt={mockupSecondary.alt_es ?? `${title} mockup secundario`} class="pd-figure" />
          </div>
        )}
      </section>
    )}

    <!-- Full-width closing detail image -->
    {detailImg && (
      <section class="pd-detail-img">
        <img src={detailImg.url} alt={detailImg.alt_es ?? `${title} detalle`} class="pd-figure" />
      </section>
    )}

    <!-- Related projects -->
    {related.length > 0 && (
      <section class="pd-related">
        <div class="pd-related__head">
          <span class="pd-related__eyebrow">Seguir explorando</span>
          <h2 class="pd-related__title">Más proyectos</h2>
        </div>
        <div class="pd-related__grid">
          {related.map((r) => {
            const Tag = r.ready ? 'a' : 'div';
            const linkAttrs = r.ready ? { href: r.href, 'data-transition-label': r.title.toUpperCase() } : {};
            return (
              <Tag class={`pd-rel ${r.ready ? '' : 'is-soon'}`} {...linkAttrs}>
                <div class="pd-rel__media">
                  <img src={r.image} alt={r.title} class="pd-rel__img" loading="lazy" />
                  {!r.ready && <span class="pd-rel__soon">Próximamente</span>}
                </div>
                <div class="pd-rel__meta">
                  <span class="pd-rel__cat">{r.category?.toUpperCase()}</span>
                  <h3 class="pd-rel__name">{r.title.toUpperCase()}</h3>
                </div>
              </Tag>
            );
          })}
        </div>
      </section>
    )}

    <!-- Prev/next — only across ready projects; hidden when there's nowhere to go -->
    {(prev || next) && (
      <nav class="pd-nav" aria-label="Navegación entre proyectos">
        {prev
          ? (
            <a href={prev.href} class="pd-nav__btn" data-transition-label={prev.title.toUpperCase()} aria-label={`Anterior: ${prev.title}`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </a>
          )
          : <span class="pd-nav__btn pd-nav__btn--off" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg></span>}
        {next
          ? (
            <a href={next.href} class="pd-nav__btn" data-transition-label={next.title.toUpperCase()} aria-label={`Siguiente: ${next.title}`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          )
          : <span class="pd-nav__btn pd-nav__btn--off" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></span>}
      </nav>
    )}

  </article>

  <script>
    // Sample the hero image's average color and feed it to the gradient (--hero-tint).
    // Pure client-side (canvas) — no server deps. Falls back to the CSS default on any failure.
    function applyHeroTint() {
      const img = document.querySelector('.pd-hero__img');
      if (!(img instanceof HTMLImageElement)) return;
      const host = img.closest('.pd') as HTMLElement | null;
      if (!host) return;
      const sample = () => {
        try {
          const canvas = document.createElement('canvas');
          canvas.width = 1;
          canvas.height = 1;
          const ctx = canvas.getContext('2d');
          if (!ctx) return;
          ctx.drawImage(img, 0, 0, 1, 1);
          const [r, g, b] = ctx.getImageData(0, 0, 1, 1).data;
          host.style.setProperty('--hero-tint', `rgb(${r}, ${g}, ${b})`);
        } catch {
          /* tainted canvas or decode error — keep the CSS fallback tint */
        }
      };
      if (img.complete && img.naturalWidth) sample();
      else img.addEventListener('load', sample, { once: true });
    }
    applyHeroTint();
    document.addEventListener('astro:page-load', applyHeroTint);
  </script>
</BaseLayout>

<style>
  .pd {
    --pad-x: 5vw;
    min-height: 100vh;
    background: var(--bg-primary);
    padding-left: 80px;            /* clear the fixed sidebar; sections are full-bleed to the right */
    overflow-x: clip;
    transition: background-color 0.3s ease;
  }

  /* HERO — full-bleed image, content anchored to the bottom */
  /* First screen: hero (flex-grow) + spec sheet (pinned bottom) fill one viewport */
  .pd-top {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }
  .pd-hero {
    position: relative;
    flex: 1 1 auto;
    min-height: 340px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: var(--bg-secondary, #111);
  }
  .pd-hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; }

  /* Gradient tinted with the image's dominant color, fading into the page at the bottom */
  .pd-hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, color-mix(in srgb, var(--hero-tint, #0b0c12) 55%, transparent) 0%, transparent 55%),
      linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0) 42%);
  }

  .pd-hero__back {
    position: absolute;
    top: 1.6rem;
    left: var(--pad-x);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .pd-hero__back:hover { color: #fff; }

  .pd-hero__content {
    position: relative;
    z-index: 2;
    padding: 0 var(--pad-x) 3rem;
    max-width: 60rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .pd-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 1.6rem;
  }
  .pd-badge::before {
    content: '';
    width: 32px;
    height: 2px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .pd-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2.8rem, 7vw, 6.5rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: #fff;
    margin: 0 0 1.1rem;
  }

  .pd-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.6vw, 1.4rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    max-width: 46ch;
    margin: 0 0 1.75rem;
  }

  .pd-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .pd-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s ease, color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .pd-btn--primary { background: var(--accent); color: var(--bg-primary); }
  .pd-btn--primary:hover { opacity: 0.85; }
  .pd-btn--ghost { color: #fff; border: 1px solid rgba(255, 255, 255, 0.35); }
  .pd-btn--ghost:hover { border-color: #fff; background: rgba(255, 255, 255, 0.08); }

  /* SPEC SHEET — full-width divider */
  .pd-specs {
    flex: 0 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 1.5rem 3rem;
    padding: 2rem var(--pad-x) 2.25rem;
    border-top: 1px solid var(--border-color);
  }
  .pd-spec { display: flex; flex-direction: column; gap: 0.7rem; }
  .pd-spec--stack { grid-column: 1 / -1; }
  .pd-spec__label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .pd-spec__value {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: clamp(1.2rem, 1.9vw, 1.7rem);
    letter-spacing: -0.01em;
    color: var(--text-primary);
    line-height: 1.15;
  }
  .pd-tags { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .pd-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .pd-tag:hover { color: var(--accent); border-color: var(--accent); }

  /* Blocks / rows — each carries a full-width top divider */
  .pd-block { padding: 4rem var(--pad-x); border-top: 1px solid var(--border-color); }
  /* Intro keeps its top divider but flows into the content below (no isolating bottom line) */
  .pd-block + .pd-row { border-top: 0; padding-top: 0; }
  .pd-lead {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: clamp(1.4rem, 2.6vw, 2.25rem);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    max-width: 60ch;
    margin: 0;
  }

  .pd-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3.5rem;
    padding: 4rem var(--pad-x);
    border-top: 1px solid var(--border-color);
  }
  .pd-row--reverse .pd-row__text { order: 2; }
  .pd-row--reverse .pd-row__media { order: 1; }
  .pd-row:not(:has(.pd-row__media)) { grid-template-columns: 1fr; }
  .pd-row:not(:has(.pd-row__media)) .pd-row__text { max-width: 60ch; }
  .pd-row:not(:has(.pd-row__text)) { grid-template-columns: 1fr; }

  .pd-h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 0 0 1.25rem;
  }
  .pd-body {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin: 0;
  }

  .pd-figure {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary, #111);
  }

  .pd-detail-img { padding: 4rem var(--pad-x); border-top: 1px solid var(--border-color); }

  /* RELATED */
  .pd-related { padding: 3.5rem var(--pad-x) 5rem; border-top: 1px solid var(--border-color); }
  .pd-related__head { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; }
  .pd-related__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .pd-related__title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0;
  }
  .pd-related__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }

  .pd-rel { display: flex; flex-direction: column; text-decoration: none; color: inherit; }
  .pd-rel__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary, #111);
    margin-bottom: 1rem;
    transition: border-color 0.3s ease;
  }
  .pd-rel__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 1s cubic-bezier(0.25, 1, 0.5, 1); }
  .pd-rel:not(.is-soon):hover .pd-rel__img { transform: scale(1.05); }
  .pd-rel:not(.is-soon):hover .pd-rel__media { border-color: var(--accent); }
  .pd-rel.is-soon { cursor: default; }

  .pd-rel__soon {
    position: absolute;
    top: 0.9rem;
    right: 1rem;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    padding: 0.25rem 0.6rem;
    backdrop-filter: blur(4px);
  }

  .pd-rel__meta { display: flex; flex-direction: column; gap: 0.35rem; }
  .pd-rel__cat {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }
  .pd-rel__name {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0;
    transition: color 0.3s ease;
  }
  .pd-rel.is-soon .pd-rel__name { color: var(--text-muted); }
  .pd-rel:not(.is-soon):hover .pd-rel__name { color: var(--accent); }

  /* PREV / NEXT */
  .pd-nav {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    z-index: 40;
    display: flex;
    gap: 0.5rem;
  }
  .pd-nav__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 10px;
    background: var(--bg-secondary, #16181f);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    text-decoration: none;
    backdrop-filter: blur(6px);
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .pd-nav__btn:hover { color: var(--accent); border-color: var(--accent); transform: translateY(-2px); }
  .pd-nav__btn--off { opacity: 0.3; pointer-events: none; }

  /* RESPONSIVE */
  @media (max-width: 992px) {
    .pd-row, .pd-row--reverse {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .pd-row--reverse .pd-row__text,
    .pd-row--reverse .pd-row__media { order: initial; }
  }

  @media (max-width: 768px) {
    .pd { --pad-x: 1.5rem; padding-left: 0; }
    .pd-related__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .pd-nav { right: 1rem; bottom: 1rem; }
  }
</style>
