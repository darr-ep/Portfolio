---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import type { Project } from '../../types/database';

export const prerender = false;

const { slug } = Astro.params;

const { data, error } = await supabase
  .from('projects')
  .select('*')
  .eq('slug', slug)
  .single();

if (!data || error) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const project = data as Project;
const title = project.title_es;
const category = project.category_es;
const description = project.description_es;
const content = project.detailed_content_es ?? '';
---

<BaseLayout title={`${title} — Edson Pedraza`} description={description} image={project.main_image ?? undefined} lang="es" includeWebPageSchema={true}>
  <div class="project-detail">
    <div class="project-detail__header">
      <a href="/#proyectos" class="back-link" data-transition-label="PROYECTOS">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Volver a proyectos
      </a>
      <span class="project-detail__cat">{category}</span>
    </div>

    {project.main_image && (
      <div class="project-detail__hero">
        <img src={project.main_image} alt={title} class="project-detail__img" />
      </div>
    )}

    <h1 class="project-detail__title">{title}</h1>
    <p class="project-detail__desc">{description}</p>

    {project.tech && project.tech.length > 0 && (
      <div class="project-detail__tech">
        {project.tech.map((t: string) => <span class="tech-tag">{t}</span>)}
      </div>
    )}

    {content && (
      <div class="project-detail__content" set:html={content.replace(/\n/g, '<br>')} />
    )}
  </div>
</BaseLayout>

<style>
  .project-detail {
    padding: 8rem 5vw 6rem calc(80px + 5vw);
    min-height: 100vh;
    background: var(--bg-primary);
    max-width: 900px;
  }

  .project-detail__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .back-link:hover { color: var(--accent); }

  .project-detail__cat {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    border: 1px solid var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 2px;
  }

  .project-detail__hero {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 3rem;
    border: 1px solid var(--border-color);
  }

  .project-detail__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-detail__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 6rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .project-detail__desc {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .project-detail__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 4rem;
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .tech-tag:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .project-detail__content {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    border-top: 1px solid var(--border-color);
    padding-top: 3rem;
  }

  @media (max-width: 768px) {
    .project-detail {
      padding: 5rem 1.5rem 4rem 1.5rem;
    }
  }
</style>
