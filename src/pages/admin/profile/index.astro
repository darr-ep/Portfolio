---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { data: profile } = await supabase
  .from('profile')
  .select('*')
  .single();

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('profile').update({
    full_name: form.get('full_name'),
    role_es: form.get('role_es'),
    role_en: form.get('role_en'),
    about_es: form.get('about_es'),
    about_en: form.get('about_en'),
    email: form.get('email'),
    phone: form.get('phone'),
    location_es: form.get('location_es'),
    location_en: form.get('location_en'),
    github_url: form.get('github_url'),
    linkedin_url: form.get('linkedin_url'),
  }).eq('id', profile!.id);
  return Astro.redirect('/admin/profile');
}
---
<AdminLayout title="Profile — Admin">
  <div class="page-header">
    <h1>Profile</h1>
  </div>

  <form method="POST" class="form">
    <div class="field">
      <label>Full name</label>
      <input type="text" name="full_name" value={profile?.full_name ?? ''} required />
    </div>
    <div class="form-row">
      <div class="field">
        <label>Role (ES)</label>
        <input type="text" name="role_es" value={profile?.role_es ?? ''} required />
      </div>
      <div class="field">
        <label>Role (EN)</label>
        <input type="text" name="role_en" value={profile?.role_en ?? ''} required />
      </div>
    </div>
    <div class="field">
      <label>About (ES)</label>
      <textarea name="about_es" rows="5">{profile?.about_es}</textarea>
    </div>
    <div class="field">
      <label>About (EN)</label>
      <textarea name="about_en" rows="5">{profile?.about_en}</textarea>
    </div>
    <div class="form-row">
      <div class="field">
        <label>Email</label>
        <input type="email" name="email" value={profile?.email ?? ''} />
      </div>
      <div class="field">
        <label>Phone</label>
        <input type="text" name="phone" value={profile?.phone ?? ''} />
      </div>
    </div>
    <div class="form-row">
      <div class="field">
        <label>Location (ES)</label>
        <input type="text" name="location_es" value={profile?.location_es ?? ''} />
      </div>
      <div class="field">
        <label>Location (EN)</label>
        <input type="text" name="location_en" value={profile?.location_en ?? ''} />
      </div>
    </div>
    <div class="field">
      <label>GitHub URL</label>
      <input type="url" name="github_url" value={profile?.github_url ?? ''} />
    </div>
    <div class="field">
      <label>LinkedIn URL</label>
      <input type="url" name="linkedin_url" value={profile?.linkedin_url ?? ''} />
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-primary">Save changes</button>
    </div>
  </form>
</AdminLayout>

<style>
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
  .page-header h1 { font-size: 24px; font-weight: 600; }
  .form { background: var(--admin-surface); border: 1px solid var(--admin-border); border-radius: 10px; padding: 28px; max-width: 700px; display: flex; flex-direction: column; gap: 16px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .field { display: flex; flex-direction: column; gap: 6px; }
  label { font-size: 12px; font-weight: 600; color: var(--admin-muted); text-transform: uppercase; letter-spacing: 0.5px; }
  input, textarea { background: var(--admin-bg); border: 1px solid var(--admin-border); border-radius: 6px; color: var(--admin-text); padding: 9px 12px; font-size: 14px; font-family: inherit; transition: border-color 0.15s; width: 100%; }
  input:focus, textarea:focus { outline: none; border-color: var(--admin-accent); }
  textarea { resize: vertical; }
  .form-actions { display: flex; gap: 12px; margin-top: 8px; }
  .btn-primary { padding: 10px 20px; background: var(--admin-accent); color: #000; border: none; border-radius: 7px; font-size: 14px; font-weight: 500; cursor: pointer; transition: opacity 0.15s; }
  .btn-primary:hover { opacity: 0.85; }
</style>
