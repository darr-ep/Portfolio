---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { data: profile } = await supabase
  .from('profile')
  .select('*')
  .single();

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('profile').update({
    full_name: form.get('full_name'),
    role_es: form.get('role_es'),
    role_en: form.get('role_en'),
    about_es: form.get('about_es'),
    about_en: form.get('about_en'),
    email: form.get('email'),
    phone: form.get('phone'),
    location_es: form.get('location_es'),
    location_en: form.get('location_en'),
    github_url: form.get('github_url'),
    linkedin_url: form.get('linkedin_url'),
  }).eq('id', profile!.id);
  return Astro.redirect('/admin/profile');
}
---
<AdminLayout title="Perfil — Admin">
  <div class="admin-page-header">
    <h1>Perfil</h1>
  </div>

  <form method="POST" class="admin-form-stack">

    <div class="admin-card">
      <span class="admin-section-title">Identidad</span>
      <div class="admin-fields">
        <div class="admin-field">
          <label class="admin-label" for="full_name">Nombre completo *</label>
          <input class="admin-input" type="text" id="full_name" name="full_name"
            value={profile?.full_name ?? ''} required />
        </div>
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="role_es">Rol (ES) *</label>
            <input class="admin-input" type="text" id="role_es" name="role_es"
              value={profile?.role_es ?? ''} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="role_en">Rol (EN) *</label>
            <input class="admin-input" type="text" id="role_en" name="role_en"
              value={profile?.role_en ?? ''} required />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Sobre mí</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="about_es">Sobre mí (ES)</label>
            <textarea class="admin-textarea" id="about_es" name="about_es"
              rows="5">{profile?.about_es}</textarea>
          </div>
          <div class="admin-field">
            <label class="admin-label" for="about_en">Sobre mí (EN)</label>
            <textarea class="admin-textarea" id="about_en" name="about_en"
              rows="5">{profile?.about_en}</textarea>
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Contacto</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="email">Correo</label>
            <input class="admin-input" type="email" id="email" name="email"
              value={profile?.email ?? ''} />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="phone">Teléfono</label>
            <input class="admin-input" type="text" id="phone" name="phone"
              value={profile?.phone ?? ''} />
          </div>
        </div>
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="location_es">Ubicación (ES)</label>
            <input class="admin-input" type="text" id="location_es" name="location_es"
              value={profile?.location_es ?? ''} />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="location_en">Ubicación (EN)</label>
            <input class="admin-input" type="text" id="location_en" name="location_en"
              value={profile?.location_en ?? ''} />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Enlaces</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="github_url">GitHub URL</label>
            <input class="admin-input" type="url" id="github_url" name="github_url"
              value={profile?.github_url ?? ''} placeholder="https://github.com/..." />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="linkedin_url">LinkedIn URL</label>
            <input class="admin-input" type="url" id="linkedin_url" name="linkedin_url"
              value={profile?.linkedin_url ?? ''} placeholder="https://linkedin.com/in/..." />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Guardar cambios</button>
    </div>

  </form>
</AdminLayout>
