---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { data: projects } = await supabase
  .from('projects')
  .select('id, sort_order, title_es, category_es, slug, year')
  .order('sort_order', { ascending: true });
---
<AdminLayout title="Projects — Admin">
  <div class="admin-page-header">
    <h1>Projects</h1>
    <div class="admin-page-header-actions">
      <span id="order-toast" class="order-toast" aria-live="polite"></span>
      <a href="/admin/projects/new" class="admin-btn admin-btn--primary">+ New project</a>
    </div>
  </div>

  <div class="admin-card table-card">
    {projects?.length ? (
      <table class="project-table">
        <thead>
          <tr>
            <th class="col-drag" aria-label="Drag to reorder"></th>
            <th>Title</th>
            <th>Category</th>
            <th>Year</th>
            <th>Slug</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="project-list">
          {projects.map((p) => (
            <tr data-id={p.id} draggable="true" class="project-row">
              <td class="col-drag drag-handle" title="Drag to reorder">
                <!-- drag grip icon (3 horizontal lines) -->
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <line x1="3" y1="12" x2="21" y2="12"/>
                  <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
              </td>
              <td class="col-title">{p.title_es}</td>
              <td class="col-muted">{p.category_es}</td>
              <td class="col-muted col-year">{p.year ?? '—'}</td>
              <td class="col-mono col-muted">{p.slug}</td>
              <td class="col-actions">
                <a href={`/admin/projects/${p.id}`} class="admin-btn admin-btn--secondary admin-btn--sm">Edit</a>
                <form action={`/admin/projects/${p.id}/delete`} method="POST" class="inline-form">
                  <button
                    type="submit"
                    class="admin-btn admin-btn--danger admin-btn--sm"
                    onclick="return confirm('Delete this project? This cannot be undone.')"
                  >Delete</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    ) : (
      <p class="empty-state">No projects yet. <a href="/admin/projects/new" class="empty-link">Create the first one.</a></p>
    )}
  </div>
</AdminLayout>

<script>
  // Native HTML5 drag-and-drop reorder. No dependencies.
  const tbody = document.getElementById('project-list');
  const toast = document.getElementById('order-toast') as HTMLElement | null;

  // Skip entirely if user prefers reduced motion (no dragging animations anyway,
  // but the drag UX itself can be disorienting -- keep functionality, drop visuals).
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (tbody) {
    let dragSrc: HTMLElement | null = null;

    function setToast(msg: string, type: 'saving' | 'success' | 'error' | '') {
      if (!toast) return;
      toast.textContent = msg;
      toast.dataset.type = type;
    }

    tbody.addEventListener('dragstart', (e) => {
      const row = (e.target as HTMLElement).closest<HTMLElement>('tr[data-id]');
      if (!row) return;
      dragSrc = row;
      if (!prefersReduced) row.dataset.dragging = 'true';
      if (e.dataTransfer) e.dataTransfer.effectAllowed = 'move';
    });

    tbody.addEventListener('dragover', (e) => {
      e.preventDefault();
      const row = (e.target as HTMLElement).closest<HTMLElement>('tr[data-id]');
      if (!row || row === dragSrc) return;
      if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
      if (!prefersReduced) row.dataset.dragover = 'true';
    });

    tbody.addEventListener('dragleave', (e) => {
      const row = (e.target as HTMLElement).closest<HTMLElement>('tr[data-id]');
      if (row) delete row.dataset.dragover;
    });

    tbody.addEventListener('drop', async (e) => {
      e.preventDefault();
      const targetRow = (e.target as HTMLElement).closest<HTMLElement>('tr[data-id]');
      if (!targetRow || !dragSrc || targetRow === dragSrc) return;

      // Clear all drag-over markers
      tbody.querySelectorAll<HTMLElement>('tr[data-id]').forEach((r) => {
        delete r.dataset.dragover;
      });

      // Reorder DOM
      const allRows = [...tbody.querySelectorAll<HTMLElement>('tr[data-id]')];
      const srcIdx = allRows.indexOf(dragSrc);
      const tgtIdx = allRows.indexOf(targetRow);

      if (srcIdx < tgtIdx) {
        targetRow.after(dragSrc);
      } else {
        targetRow.before(dragSrc);
      }

      delete dragSrc.dataset.dragging;
      dragSrc = null;

      // Collect new id order
      const ids = [...tbody.querySelectorAll<HTMLElement>('tr[data-id]')]
        .map((r) => r.dataset.id!)
        .filter(Boolean);

      setToast('Saving…', 'saving');

      try {
        const res = await fetch('/api/admin/reorder-projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids }),
        });
        const json = await res.json() as { success: boolean; error?: string };
        if (json.success) {
          setToast('Order saved', 'success');
          setTimeout(() => setToast('', ''), 2200);
        } else {
          setToast(`Error: ${json.error ?? 'unknown'}`, 'error');
        }
      } catch {
        setToast('Network error — order not saved', 'error');
      }
    });

    tbody.addEventListener('dragend', () => {
      tbody.querySelectorAll<HTMLElement>('tr[data-id]').forEach((r) => {
        delete r.dataset.dragging;
        delete r.dataset.dragover;
      });
      dragSrc = null;
    });
  }
</script>

<style>
  .table-card {
    padding: 0;
    overflow: hidden;
  }

  .project-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  thead th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-muted);
    border-bottom: 1px solid var(--admin-border);
  }

  .col-drag {
    width: 40px;
    padding-left: 14px !important;
    padding-right: 6px !important;
  }

  td {
    padding: 13px 16px;
    border-bottom: 1px solid var(--admin-border);
    vertical-align: middle;
  }

  tbody tr:last-child td { border-bottom: none; }

  /* Row hover */
  .project-row { transition: background 0.1s ease; }
  .project-row:hover td { background: rgba(255, 255, 255, 0.025); }
  html.light .project-row:hover td { background: rgba(0, 0, 0, 0.025); }

  /* Drag states */
  .project-row[data-dragging] td { opacity: 0.45; }
  .project-row[data-dragover] td { background: rgba(227, 168, 87, 0.08); }

  @media (prefers-reduced-motion: reduce) {
    .project-row[data-dragging] td { opacity: 1; }
    .project-row[data-dragover] td { outline: 2px solid var(--admin-accent); }
  }

  .drag-handle {
    cursor: grab;
    color: var(--admin-muted);
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .project-row:hover .drag-handle { opacity: 1; }
  .drag-handle:active { cursor: grabbing; }

  .col-muted { color: var(--admin-muted); }
  .col-mono { font-family: var(--font-mono, monospace); font-size: 12px; }
  .col-year { width: 72px; }

  .col-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    white-space: nowrap;
  }

  .inline-form { display: contents; }

  .col-title { font-weight: 500; }

  /* Empty state */
  .empty-state {
    padding: 48px 28px;
    text-align: center;
    color: var(--admin-muted);
    font-size: 14px;
  }

  .empty-link {
    color: var(--admin-accent);
    text-decoration: underline;
  }

  /* Order saved toast */
  .order-toast {
    font-size: 12px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 6px;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .order-toast:not(:empty) { opacity: 1; }

  .order-toast[data-type="saving"] {
    color: var(--admin-muted);
    background: transparent;
  }

  .order-toast[data-type="success"] {
    color: var(--success, #22c55e);
    background: rgba(34, 197, 94, 0.1);
  }

  .order-toast[data-type="error"] {
    color: var(--danger, #ef4444);
    background: rgba(239, 68, 68, 0.1);
  }
</style>
