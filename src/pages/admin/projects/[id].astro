---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import type { ProjectImage } from '../../../types/database';
import { CV_IMPACT_SLOTS } from '../../../lib/cv-projection';

const { id } = Astro.params;
let saveError: string | null = null;

// Approach is authored as up to 4 "beats" (big statement + support paragraph).
const BEAT_SLOTS = 4;

// Handle text-field save (separate from image upload)
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const tech = (form.get('tech') as string ?? '')
    .split(',')
    .map((t) => t.trim())
    .filter(Boolean);

  const title_es   = (form.get('title_es')      as string) || '';
  const title_en   = (form.get('title_en')      as string) || title_es;
  const cat_es     = (form.get('category_es')   as string) || '';
  const cat_en     = (form.get('category_en')   as string) || cat_es;
  const desc_es    = (form.get('description_es') as string) || '';
  const desc_en    = (form.get('description_en') as string) || desc_es;

  // Collect the beat slots into { lead, body }[] per language, skipping empties.
  const beats_es: { lead: string; body: string }[] = [];
  const beats_en: { lead: string; body: string }[] = [];
  for (let i = 0; i < BEAT_SLOTS; i++) {
    const leadEs = ((form.get(`beat_${i}_lead_es`) as string) || '').trim();
    const bodyEs = ((form.get(`beat_${i}_body_es`) as string) || '').trim();
    const leadEn = ((form.get(`beat_${i}_lead_en`) as string) || '').trim();
    const bodyEn = ((form.get(`beat_${i}_body_en`) as string) || '').trim();
    if (leadEs || bodyEs) beats_es.push({ lead: leadEs, body: bodyEs });
    if (leadEn || bodyEn) beats_en.push({ lead: leadEn, body: bodyEn });
  }

  // Public visibility: hidden projects are unpublished across all public routes.
  const is_visible = form.get('is_visible') === 'on';

  // CV export: visibility toggle + problem sentence + fixed impact slots per locale.
  const cv_visible = form.get('cv_visible') === 'on';
  const cv_problem_es = (form.get('cv_problem_es') as string) || null;
  const cv_problem_en = (form.get('cv_problem_en') as string) || null;

  const cv_impact_es: { lead: string; body: string }[] = [];
  const cv_impact_en: { lead: string; body: string }[] = [];
  for (let i = 0; i < CV_IMPACT_SLOTS; i++) {
    const leadEs = ((form.get(`cv_impact_${i}_lead_es`) as string) || '').trim();
    const bodyEs = ((form.get(`cv_impact_${i}_body_es`) as string) || '').trim();
    const leadEn = ((form.get(`cv_impact_${i}_lead_en`) as string) || '').trim();
    const bodyEn = ((form.get(`cv_impact_${i}_body_en`) as string) || '').trim();
    if (leadEs || bodyEs) cv_impact_es.push({ lead: leadEs, body: bodyEs });
    if (leadEn || bodyEn) cv_impact_en.push({ lead: leadEn, body: bodyEn });
  }

  // sort_order is managed by drag-to-reorder -- never touched here.
  const { error } = await supabase
    .from('projects')
    .update({
      slug:              form.get('slug'),
      title_es,
      title_en,
      category_es:       cat_es,
      category_en:       cat_en,
      description_es:    desc_es,
      description_en:    desc_en,
      tagline_es:        form.get('tagline_es')         || null,
      tagline_en:        form.get('tagline_en')         || null,
      role_es:           form.get('role_es')            || null,
      role_en:           form.get('role_en')            || null,
      collaborators:     form.get('collaborators')      || null,
      year:              form.get('year') ? Number(form.get('year')) : null,
      live_url:          form.get('live_url')           || null,
      github_url:        form.get('github_url')         || null,
      beats_es:          beats_es.length ? beats_es : null,
      beats_en:          beats_en.length ? beats_en : null,
      conclusion_es:     form.get('conclusion_es')      || null,
      conclusion_en:     form.get('conclusion_en')      || null,
      tech,
      main_image:        form.get('main_image')         || null,
      is_visible,
      cv_visible,
      cv_problem_es,
      cv_problem_en,
      cv_impact_es:      cv_impact_es.length ? cv_impact_es : null,
      cv_impact_en:      cv_impact_en.length ? cv_impact_en : null,
    })
    .eq('id', id!);

  if (error) {
    saveError = error.message;
  } else {
    // Stay on the edit page so the user can manage images right away.
    return Astro.redirect(`/admin/projects/${id}`);
  }
}

// Fetch project
const { data: project } = await supabase
  .from('projects')
  .select('*')
  .eq('id', id!)
  .single();

if (!project) {
  return Astro.redirect('/admin/projects');
}

// Fetch images for the inline image section
const { data: rawImages } = await supabase
  .from('project_images')
  .select('*')
  .eq('project_id', id!);

const imagesBySlot: Record<string, ProjectImage | undefined> = {};
for (const img of rawImages ?? []) {
  imagesBySlot[img.slot_key] = img as ProjectImage;
}

// Pre-fill the beat slots from the stored arrays (may be shorter than BEAT_SLOTS).
const beatsEs = (project.beats_es ?? []) as { lead: string; body: string }[];
const beatsEn = (project.beats_en ?? []) as { lead: string; body: string }[];

// CV export fields — tolerant of the columns not existing yet (pre-migration),
// in which case `project.cv_*` is simply undefined and these fall back safely.
const isVisible = project.is_visible;
const cvVisible = project.cv_visible ?? false;
const cvProblemEs = project.cv_problem_es ?? '';
const cvProblemEn = project.cv_problem_en ?? '';
const cvImpactEs = (project.cv_impact_es ?? []) as { lead: string; body: string }[];
const cvImpactEn = (project.cv_impact_en ?? []) as { lead: string; body: string }[];

const IMAGE_SLOTS = [
  { key: 'hero',             label: 'Hero / Portada' },
  { key: 'mockup_main',      label: 'Mockup principal' },
  { key: 'mockup_secondary', label: 'Mockup secundario' },
  { key: 'detail',           label: 'Detalle' },
] as const;
---
<AdminLayout title={`Editar: ${project.title_es} — Admin`}>

  <div class="admin-page-header">
    <h1>Editar proyecto</h1>
    <div class="admin-page-header-actions">
      <a href={`/${project.slug}`} target="_blank" rel="noopener noreferrer"
        class="admin-btn admin-btn--secondary admin-btn--sm">Ver público</a>
      <a href="/admin/projects" class="admin-btn admin-btn--secondary">Volver a la lista</a>
    </div>
  </div>

  {saveError && (
    <div class="error-notice">{saveError}</div>
  )}

  <!-- Main text-fields form -->
  <form method="POST" class="admin-form-stack" id="project-form">

    <!-- Section: Basics -->
    <div class="admin-card">
      <span class="admin-section-title">Datos básicos</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="slug">Slug *</label>
            <input class="admin-input" type="text" id="slug" name="slug"
              value={project.slug} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="year">Año</label>
            <input class="admin-input" type="number" id="year" name="year"
              value={project.year ?? ''} min="2000" max="2099" />
          </div>
        </div>

        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="title_es">Título (ES) *</label>
            <input class="admin-input" type="text" id="title_es" name="title_es"
              value={project.title_es} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="title_en">Título (EN)</label>
            <input class="admin-input" type="text" id="title_en" name="title_en"
              value={project.title_en} />
          </div>
        </div>

        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="category_es">Categoría (ES) *</label>
            <input class="admin-input" type="text" id="category_es" name="category_es"
              value={project.category_es} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="category_en">Categoría (EN)</label>
            <input class="admin-input" type="text" id="category_en" name="category_en"
              value={project.category_en} />
          </div>
        </div>

        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="tech">Tecnologías (separadas por comas)</label>
            <input class="admin-input" type="text" id="tech" name="tech"
              value={project.tech?.join(', ') ?? ''} />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="main_image">URL de la imagen principal</label>
            <input class="admin-input" type="text" id="main_image" name="main_image"
              value={project.main_image ?? ''} />
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Introduction -->
    <div class="admin-card">
      <span class="admin-section-title">Introducción</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="tagline_es">Tagline (ES)</label>
            <input class="admin-input" type="text" id="tagline_es" name="tagline_es"
              value={project.tagline_es ?? ''} />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="tagline_en">Tagline (EN)</label>
            <input class="admin-input" type="text" id="tagline_en" name="tagline_en"
              value={project.tagline_en ?? ''} />
          </div>
        </div>

        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="role_es">Rol (ES)</label>
            <input class="admin-input" type="text" id="role_es" name="role_es"
              value={project.role_es ?? ''} />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="role_en">Rol (EN)</label>
            <input class="admin-input" type="text" id="role_en" name="role_en"
              value={project.role_en ?? ''} />
          </div>
        </div>

        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="collaborators">Colaboradores</label>
            <input class="admin-input" type="text" id="collaborators" name="collaborators"
              value={project.collaborators ?? ''} />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="live_url">URL del sitio</label>
            <input class="admin-input" type="url" id="live_url" name="live_url"
              value={project.live_url ?? ''} placeholder="https://…" />
          </div>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="github_url">GitHub URL</label>
          <input class="admin-input" type="url" id="github_url" name="github_url"
            value={project.github_url ?? ''} placeholder="https://github.com/…" />
        </div>

        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="description_es">Descripción (ES) *</label>
            <textarea class="admin-textarea" id="description_es" name="description_es"
              rows="4" required>{project.description_es}</textarea>
          </div>
          <div class="admin-field">
            <label class="admin-label" for="description_en">Descripción (EN)</label>
            <textarea class="admin-textarea" id="description_en" name="description_en"
              rows="4">{project.description_en}</textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: public visibility -->
    <div class="admin-card">
      <span class="admin-section-title">Visibilidad pública</span>
      <p class="beats-hint">Si está desmarcado, el proyecto no aparece en la landing, el índice de proyectos ni el sitemap, y sus URLs directas responden 404. Úsalo para proyectos aún sin caso de estudio; márcalo cuando esté listo para publicar.</p>
      <div class="admin-fields">
        <label class="admin-checkbox-label">
          <input type="checkbox" name="is_visible" checked={isVisible} />
          Mostrar este proyecto en el sitio público
        </label>
      </div>
    </div>

    <!-- Section: CV export (problem + impact) -->
    <div class="admin-card">
      <span class="admin-section-title">Currículum (CV) — problema e impacto</span>
      <p class="beats-hint">Controla si este proyecto aparece en el CV descargable (/cv.pdf) y el bloque "problema → impacto" que se muestra ahí. No afecta la página pública del proyecto. Nota: en el CV, el título usa el <strong>Tagline</strong> como subtítulo; la <strong>Descripción</strong> NO sale en el CV (solo en las tarjetas públicas de proyectos).</p>
      <div class="admin-fields">
        <label class="admin-checkbox-label">
          <input type="checkbox" name="cv_visible" checked={cvVisible} />
          Mostrar este proyecto en el CV
        </label>

        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="cv_problem_es">Problema (ES)</label>
            <textarea class="admin-textarea" id="cv_problem_es" name="cv_problem_es"
              rows="3">{cvProblemEs}</textarea>
          </div>
          <div class="admin-field">
            <label class="admin-label" for="cv_problem_en">Problema (EN)</label>
            <textarea class="admin-textarea" id="cv_problem_en" name="cv_problem_en"
              rows="3">{cvProblemEn}</textarea>
          </div>
        </div>

        {Array.from({ length: CV_IMPACT_SLOTS }).map((_, i) => (
          <div class="beat-slot">
            <span class="beat-slot__label">Impacto {i + 1}</span>
            <div class="admin-row">
              <div class="admin-field">
                <label class="admin-label">Frase (ES)</label>
                <input class="admin-input" type="text" name={`cv_impact_${i}_lead_es`} value={cvImpactEs[i]?.lead ?? ''} />
              </div>
              <div class="admin-field">
                <label class="admin-label">Frase (EN)</label>
                <input class="admin-input" type="text" name={`cv_impact_${i}_lead_en`} value={cvImpactEn[i]?.lead ?? ''} />
              </div>
            </div>
            <div class="admin-row">
              <div class="admin-field">
                <label class="admin-label">Detalle (ES)</label>
                <textarea class="admin-textarea" name={`cv_impact_${i}_body_es`} rows="2">{cvImpactEs[i]?.body ?? ''}</textarea>
              </div>
              <div class="admin-field">
                <label class="admin-label">Detalle (EN)</label>
                <textarea class="admin-textarea" name={`cv_impact_${i}_body_en`} rows="2">{cvImpactEn[i]?.body ?? ''}</textarea>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Section: Approach (beats) -->
    <div class="admin-card">
      <span class="admin-section-title">Enfoque — bloques</span>
      <p class="beats-hint">Cada bloque es una frase grande + un texto de apoyo; se alternan de lado en la página. Deja un bloque vacío para omitirlo. El cierre grande final es la Conclusión.</p>
      <div class="admin-fields">
        {Array.from({ length: BEAT_SLOTS }).map((_, i) => (
          <div class="beat-slot">
            <span class="beat-slot__label">Bloque {i + 1}{i === 0 ? ' · con mockup principal' : i === 1 ? ' · con mockup secundario' : ''}</span>
            <div class="admin-row">
              <div class="admin-field">
                <label class="admin-label">Frase grande (ES)</label>
                <input class="admin-input" type="text" name={`beat_${i}_lead_es`} value={beatsEs[i]?.lead ?? ''} />
              </div>
              <div class="admin-field">
                <label class="admin-label">Frase grande (EN)</label>
                <input class="admin-input" type="text" name={`beat_${i}_lead_en`} value={beatsEn[i]?.lead ?? ''} />
              </div>
            </div>
            <div class="admin-row">
              <div class="admin-field">
                <label class="admin-label">Texto de apoyo (ES)</label>
                <textarea class="admin-textarea" name={`beat_${i}_body_es`} rows="3">{beatsEs[i]?.body ?? ''}</textarea>
              </div>
              <div class="admin-field">
                <label class="admin-label">Texto de apoyo (EN)</label>
                <textarea class="admin-textarea" name={`beat_${i}_body_en`} rows="3">{beatsEn[i]?.body ?? ''}</textarea>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Section: Conclusion -->
    <div class="admin-card">
      <span class="admin-section-title">Conclusión</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="conclusion_es">Conclusión (ES)</label>
            <textarea class="admin-textarea" id="conclusion_es" name="conclusion_es"
              rows="4">{project.conclusion_es}</textarea>
          </div>
          <div class="admin-field">
            <label class="admin-label" for="conclusion_en">Conclusión (EN)</label>
            <textarea class="admin-textarea" id="conclusion_en" name="conclusion_en"
              rows="4">{project.conclusion_en}</textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- Form actions -->
    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Guardar cambios</button>
      <a href="/admin/projects" class="admin-btn admin-btn--secondary">Cancelar</a>
    </div>

  </form>

  <!-- Inline image management (separate from the text form) -->
  <section class="images-section" aria-labelledby="images-heading">
    <div class="section-divider admin-page-header" style="margin-top: 36px;">
      <h2 id="images-heading" style="font-size: 18px; font-weight: 600;">Mockups / Capturas</h2>
    </div>

    <div class="image-grid admin-form-stack" style="max-width: 940px;">
      {IMAGE_SLOTS.map(({ key, label }) => {
        const img = imagesBySlot[key];
        return (
          <div class="admin-card image-slot">
            <span class="admin-section-title">
              {label}
              {img && <span class="slot-badge">Subido</span>}
            </span>

            {img ? (
              <div class="slot-filled">
                <img
                  src={img.url}
                  alt={img.alt_es ?? label}
                  class="slot-preview"
                  loading="lazy"
                />
                <!-- Edit alt text in place — no need to delete and re-upload -->
                <form action="/api/admin/update-image-alt" method="POST" class="slot-alts">
                  <input type="hidden" name="image_id" value={img.id} />
                  <div class="admin-row">
                    <div class="admin-field">
                      <label class="admin-label">Texto alternativo (ES)</label>
                      <input class="admin-input" type="text" name="alt_es"
                        value={img.alt_es ?? ''} placeholder="Descripción de la imagen" />
                    </div>
                    <div class="admin-field">
                      <label class="admin-label">Texto alternativo (EN)</label>
                      <input class="admin-input" type="text" name="alt_en"
                        value={img.alt_en ?? ''} placeholder="Image description" />
                    </div>
                  </div>
                  <div class="upload-actions">
                    <button type="submit" class="admin-btn admin-btn--primary admin-btn--sm">Guardar alt</button>
                  </div>
                </form>
                <!-- Delete form: POSTs to the existing API; redirects back via Referer -->
                <form action="/api/admin/delete-project-image" method="POST" class="delete-img-form">
                  <input type="hidden" name="image_id" value={img.id} />
                  <input type="hidden" name="storage_path" value={img.storage_path} />
                  <button
                    type="submit"
                    class="admin-btn admin-btn--danger admin-btn--sm"
                    onclick="return confirm('¿Eliminar esta imagen? No se puede deshacer.')"
                  >Eliminar imagen</button>
                </form>
              </div>
            ) : (
              <div class="slot-empty">
                <p class="slot-empty-msg">Aún no se ha subido ninguna imagen.</p>
                <!-- Upload form handled by JS fetch below -->
                <form class="upload-form" data-slot={key} data-project={id}>
                  <input type="hidden" name="slot_key" value={key} />
                  <input type="hidden" name="project_id" value={id} />
                  <div class="admin-fields">
                    <div class="admin-field">
                      <label class="admin-label">Archivo de imagen *</label>
                      <input class="admin-input" type="file" name="file"
                        accept="image/*" required />
                    </div>
                    <div class="admin-row">
                      <div class="admin-field">
                        <label class="admin-label">Texto alternativo (ES)</label>
                        <input class="admin-input" type="text" name="alt_es"
                          placeholder="Descripción de la imagen" />
                      </div>
                      <div class="admin-field">
                        <label class="admin-label">Texto alternativo (EN)</label>
                        <input class="admin-input" type="text" name="alt_en"
                          placeholder="Image description" />
                      </div>
                    </div>
                    <div class="upload-actions">
                      <button type="submit" class="admin-btn admin-btn--primary admin-btn--sm">
                        Subir
                      </button>
                      <span class="upload-status" aria-live="polite"></span>
                    </div>
                  </div>
                </form>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <!-- Danger zone (delete project -- separate from all other forms) -->
  <section class="danger-section" aria-label="Zona de peligro">
    <div class="admin-card danger-card">
      <span class="admin-section-title" style="color: var(--danger, #ef4444);">Zona de peligro</span>
      <p class="danger-msg">Eliminar este proyecto y todas sus imágenes de forma permanente. No se puede deshacer.</p>
      <form action={`/admin/projects/${id}/delete`} method="POST">
        <button
          type="submit"
          class="admin-btn admin-btn--danger"
          onclick="return confirm('¿Eliminar este proyecto? También se eliminarán todas las imágenes. Esta acción no se puede deshacer.')"
        >Eliminar proyecto</button>
      </form>
    </div>
  </section>

</AdminLayout>

<!-- Image upload via fetch (the one allowed client JS exception in admin pages) -->
<script>
  document.querySelectorAll<HTMLFormElement>('.upload-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const statusEl  = form.querySelector<HTMLElement>('.upload-status');
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

      if (submitBtn) submitBtn.disabled = true;
      if (statusEl) statusEl.textContent = 'Subiendo...';

      const data = new FormData(form);

      try {
        const res  = await fetch('/api/admin/upload-image', { method: 'POST', body: data });
        const json = await res.json() as { success: boolean; error?: string };

        if (json.success) {
          window.location.reload();
        } else {
          if (statusEl) statusEl.textContent = `Error: ${json.error ?? 'desconocido'}`;
          if (submitBtn) submitBtn.disabled = false;
        }
      } catch {
        if (statusEl) statusEl.textContent = 'Error de red. Inténtalo de nuevo.';
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  });
</script>

<style>
  .error-notice {
    font-size: 13px;
    color: var(--danger, #ef4444);
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 20px;
    max-width: 940px;
  }

  /* CV checkbox toggle */
  .admin-checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--admin-text);
    cursor: pointer;
  }
  .admin-checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--admin-accent);
    cursor: pointer;
  }

  /* Beats editor */
  .beats-hint {
    font-size: 12px;
    color: var(--admin-muted);
    margin: -4px 0 6px;
