---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('education').insert({
    sort_order: Number(form.get('sort_order')),
    institution: form.get('institution'),
    period: form.get('period'),
    degree_es: form.get('degree_es'),
    degree_en: form.get('degree_en'),
    description_es: form.get('description_es'),
    description_en: form.get('description_en'),
  });
  return Astro.redirect('/admin/education');
}
---
<AdminLayout title="Nueva formación — Admin">
  <div class="admin-page-header">
    <h1>Nueva formación</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/education" class="admin-btn admin-btn--secondary">Volver a la lista</a>
    </div>
  </div>

  <form method="POST" class="admin-form-stack">

    <div class="admin-card">
      <span class="admin-section-title">Datos básicos</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="institution">Institución *</label>
            <input class="admin-input" type="text" id="institution" name="institution" required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="sort_order">Orden</label>
            <input class="admin-input" type="number" id="sort_order" name="sort_order"
              value="0" required />
          </div>
        </div>
        <div class="admin-field">
          <label class="admin-label" for="period">Período *</label>
          <input class="admin-input" type="text" id="period" name="period"
            placeholder="2020 - 2024" required />
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Título</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="degree_es">Título (ES) *</label>
            <input class="admin-input" type="text" id="degree_es" name="degree_es" required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="degree_en">Título (EN) *</label>
            <input class="admin-input" type="text" id="degree_en" name="degree_en" required />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Descripción</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="description_es">Descripción (ES)</label>
            <textarea class="admin-textarea" id="description_es" name="description_es"
              rows="4"></textarea>
          </div>
          <div class="admin-field">
            <label class="admin-label" for="description_en">Descripción (EN)</label>
            <textarea class="admin-textarea" id="description_en" name="description_en"
              rows="4"></textarea>
          </div>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Crear formación</button>
      <a href="/admin/education" class="admin-btn admin-btn--secondary">Cancelar</a>
    </div>

  </form>
</AdminLayout>
