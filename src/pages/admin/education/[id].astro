---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { id } = Astro.params;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('education').update({
    sort_order: Number(form.get('sort_order')),
    institution: form.get('institution'),
    period: form.get('period'),
    degree_es: form.get('degree_es'),
    degree_en: form.get('degree_en'),
    description_es: form.get('description_es'),
    description_en: form.get('description_en'),
  }).eq('id', id!);
  return Astro.redirect('/admin/education');
}

const { data: entry } = await supabase
  .from('education')
  .select('*')
  .eq('id', id!)
  .single();

if (!entry) {
  return Astro.redirect('/admin/education');
}
---
<AdminLayout title={`Edit: ${entry.institution} — Admin`}>

  <div class="admin-page-header">
    <h1>Edit Education Entry</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/education" class="admin-btn admin-btn--secondary">Back to list</a>
    </div>
  </div>

  <form method="POST" class="admin-form-stack">

    <div class="admin-card">
      <span class="admin-section-title">Basics</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="institution">Institution *</label>
            <input class="admin-input" type="text" id="institution" name="institution"
              value={entry.institution} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="sort_order">Sort order</label>
            <input class="admin-input" type="number" id="sort_order" name="sort_order"
              value={entry.sort_order} required />
          </div>
        </div>
        <div class="admin-field">
          <label class="admin-label" for="period">Period *</label>
          <input class="admin-input" type="text" id="period" name="period"
            value={entry.period} required />
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Degree</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="degree_es">Degree (ES) *</label>
            <input class="admin-input" type="text" id="degree_es" name="degree_es"
              value={entry.degree_es} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="degree_en">Degree (EN) *</label>
            <input class="admin-input" type="text" id="degree_en" name="degree_en"
              value={entry.degree_en} required />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Description</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="description_es">Description (ES)</label>
            <textarea class="admin-textarea" id="description_es" name="description_es"
              rows="4">{entry.description_es}</textarea>
          </div>
          <div class="admin-field">
            <label class="admin-label" for="description_en">Description (EN)</label>
            <textarea class="admin-textarea" id="description_en" name="description_en"
              rows="4">{entry.description_en}</textarea>
          </div>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Save changes</button>
      <a href="/admin/education" class="admin-btn admin-btn--secondary">Cancel</a>
    </div>

  </form>

  <section class="danger-section" aria-label="Danger zone">
    <div class="admin-card danger-card">
      <span class="admin-section-title" style="color: var(--danger, #ef4444);">Danger Zone</span>
      <p class="danger-msg">Permanently delete this education entry. This cannot be undone.</p>
      <form action={`/admin/education/${id}/delete`} method="POST">
        <button
          type="submit"
          class="admin-btn admin-btn--danger"
          onclick="return confirm('Delete this entry? This cannot be undone.')"
        >Delete entry</button>
      </form>
    </div>
  </section>

</AdminLayout>

<style>
  .danger-section { margin-top: 36px; max-width: 940px; }
  .danger-card { border-color: rgba(239, 68, 68, 0.25); }
  .danger-msg { font-size: 13px; color: var(--admin-muted); margin-bottom: 16px; }
</style>
