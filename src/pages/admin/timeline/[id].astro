---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { id } = Astro.params;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('timeline').update({
    sort_order: Number(form.get('sort_order')),
    year: form.get('year'),
    company: form.get('company'),
    role_es: form.get('role_es'),
    role_en: form.get('role_en'),
    description_es: form.get('description_es'),
    description_en: form.get('description_en'),
    entry_type: form.get('entry_type') ?? 'work',
  }).eq('id', id!);
  return Astro.redirect('/admin/timeline');
}

const { data: entry } = await supabase
  .from('timeline')
  .select('*')
  .eq('id', id!)
  .single();

if (!entry) {
  return Astro.redirect('/admin/timeline');
}
---
<AdminLayout title={`Edit: ${entry.company} — Admin`}>

  <div class="admin-page-header">
    <h1>Edit Timeline Entry</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/timeline" class="admin-btn admin-btn--secondary">Back to list</a>
    </div>
  </div>

  <form method="POST" class="admin-form-stack">

    <div class="admin-card">
      <span class="admin-section-title">Basics</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="year">Year *</label>
            <input class="admin-input" type="text" id="year" name="year"
              value={entry.year} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="sort_order">Sort order</label>
            <input class="admin-input" type="number" id="sort_order" name="sort_order"
              value={entry.sort_order} required />
          </div>
        </div>
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="company">Company / Institution / Project *</label>
            <input class="admin-input" type="text" id="company" name="company"
              value={entry.company} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="entry_type">Type</label>
            <select class="admin-select" id="entry_type" name="entry_type" required>
              <option value="work"          selected={entry.entry_type === 'work'}>Work</option>
              <option value="freelance"     selected={entry.entry_type === 'freelance'}>Freelance</option>
              <option value="education"     selected={entry.entry_type === 'education'}>Education</option>
              <option value="project"       selected={entry.entry_type === 'project'}>Project</option>
              <option value="certification" selected={entry.entry_type === 'certification'}>Certification</option>
              <option value="milestone"     selected={entry.entry_type === 'milestone'}>Milestone</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Role</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="role_es">Role (ES) *</label>
            <input class="admin-input" type="text" id="role_es" name="role_es"
              value={entry.role_es} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="role_en">Role (EN) *</label>
            <input class="admin-input" type="text" id="role_en" name="role_en"
              value={entry.role_en} required />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Description</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="description_es">Description (ES) *</label>
            <textarea class="admin-textarea" id="description_es" name="description_es"
              rows="4" required>{entry.description_es}</textarea>
          </div>
          <div class="admin-field">
            <label class="admin-label" for="description_en">Description (EN) *</label>
            <textarea class="admin-textarea" id="description_en" name="description_en"
              rows="4" required>{entry.description_en}</textarea>
          </div>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Save changes</button>
      <a href="/admin/timeline" class="admin-btn admin-btn--secondary">Cancel</a>
    </div>

  </form>

  <section class="danger-section" aria-label="Danger zone">
    <div class="admin-card danger-card">
      <span class="admin-section-title" style="color: var(--danger, #ef4444);">Danger Zone</span>
      <p class="danger-msg">Permanently delete this timeline entry. This cannot be undone.</p>
      <form action={`/admin/timeline/${id}/delete`} method="POST">
        <button
          type="submit"
          class="admin-btn admin-btn--danger"
          onclick="return confirm('Delete this entry? This cannot be undone.')"
        >Delete entry</button>
      </form>
    </div>
  </section>

</AdminLayout>

<style>
  .danger-section { margin-top: 36px; max-width: 940px; }
  .danger-card { border-color: rgba(239, 68, 68, 0.25); }
  .danger-msg { font-size: 13px; color: var(--admin-muted); margin-bottom: 16px; }
</style>
