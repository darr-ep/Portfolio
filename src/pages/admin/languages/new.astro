---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('languages').insert({
    sort_order: Number(form.get('sort_order')),
    name_es: form.get('name_es'),
    name_en: form.get('name_en'),
    level_es: form.get('level_es'),
    level_en: form.get('level_en'),
  });
  return Astro.redirect('/admin/languages');
}
---
<AdminLayout title="Nuevo idioma — Admin">
  <div class="admin-page-header">
    <h1>Nuevo idioma</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/languages" class="admin-btn admin-btn--secondary">Volver a la lista</a>
    </div>
  </div>

  <form method="POST" class="admin-form-stack">

    <div class="admin-card">
      <span class="admin-section-title">Datos básicos</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="name_es">Nombre (ES) *</label>
            <input class="admin-input" type="text" id="name_es" name="name_es" required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="name_en">Nombre (EN) *</label>
            <input class="admin-input" type="text" id="name_en" name="name_en" required />
          </div>
        </div>
        <div class="admin-field">
          <label class="admin-label" for="sort_order">Orden</label>
          <input class="admin-input" type="number" id="sort_order" name="sort_order"
            value="0" required />
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Nivel</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="level_es">Nivel (ES) *</label>
            <input class="admin-input" type="text" id="level_es" name="level_es"
              placeholder="Nativo" required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="level_en">Nivel (EN) *</label>
            <input class="admin-input" type="text" id="level_en" name="level_en"
              placeholder="Native" required />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Crear idioma</button>
      <a href="/admin/languages" class="admin-btn admin-btn--secondary">Cancelar</a>
    </div>

  </form>
</AdminLayout>
