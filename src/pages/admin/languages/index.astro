---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { data: entries } = await supabase
  .from('languages')
  .select('id, sort_order, name_es, level_es')
  .order('sort_order');
---
<AdminLayout title="Languages — Admin">
  <div class="admin-page-header">
    <h1>Languages</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/languages/new" class="admin-btn admin-btn--primary">+ New entry</a>
    </div>
  </div>

  <div class="admin-card table-card">
    {entries?.length ? (
      <table class="list-table">
        <thead>
          <tr>
            <th>Sort</th>
            <th>Name</th>
            <th>Level</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {entries.map((e) => (
            <tr>
              <td class="col-muted">{e.sort_order}</td>
              <td class="col-name">{e.name_es}</td>
              <td class="col-muted">{e.level_es}</td>
              <td class="col-actions">
                <a href={`/admin/languages/${e.id}`} class="admin-btn admin-btn--secondary admin-btn--sm">Edit</a>
                <form action={`/admin/languages/${e.id}/delete`} method="POST" class="inline-form">
                  <button
                    type="submit"
                    class="admin-btn admin-btn--danger admin-btn--sm"
                    onclick="return confirm('Delete this entry?')"
                  >Delete</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    ) : (
      <p class="empty-state">No language entries yet. <a href="/admin/languages/new" class="empty-link">Create the first one.</a></p>
    )}
  </div>
</AdminLayout>

<style>
  .table-card { padding: 0; overflow: hidden; }

  .list-table { width: 100%; border-collapse: collapse; font-size: 14px; }

  thead th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-muted);
    border-bottom: 1px solid var(--admin-border);
  }

  td {
    padding: 13px 16px;
    border-bottom: 1px solid var(--admin-border);
    vertical-align: middle;
  }

  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: rgba(255, 255, 255, 0.025); }
  html.light tbody tr:hover td { background: rgba(0, 0, 0, 0.025); }

  .col-muted { color: var(--admin-muted); }
  .col-name { font-weight: 500; }

  .col-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    white-space: nowrap;
  }

  .inline-form { display: contents; }

  .empty-state {
    padding: 48px 28px;
    text-align: center;
    color: var(--admin-muted);
    font-size: 14px;
  }

  .empty-link {
    color: var(--admin-accent);
    text-decoration: underline;
  }
</style>
