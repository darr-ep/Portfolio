---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { id } = Astro.params;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('languages').update({
    sort_order: Number(form.get('sort_order')),
    name_es: form.get('name_es'),
    name_en: form.get('name_en'),
    level_es: form.get('level_es'),
    level_en: form.get('level_en'),
  }).eq('id', id!);
  return Astro.redirect('/admin/languages');
}

const { data: entry } = await supabase
  .from('languages')
  .select('*')
  .eq('id', id!)
  .single();

if (!entry) {
  return Astro.redirect('/admin/languages');
}
---
<AdminLayout title={`Edit: ${entry.name_es} — Admin`}>

  <div class="admin-page-header">
    <h1>Edit Language Entry</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/languages" class="admin-btn admin-btn--secondary">Back to list</a>
    </div>
  </div>

  <form method="POST" class="admin-form-stack">

    <div class="admin-card">
      <span class="admin-section-title">Basics</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="name_es">Name (ES) *</label>
            <input class="admin-input" type="text" id="name_es" name="name_es"
              value={entry.name_es} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="name_en">Name (EN) *</label>
            <input class="admin-input" type="text" id="name_en" name="name_en"
              value={entry.name_en} required />
          </div>
        </div>
        <div class="admin-field">
          <label class="admin-label" for="sort_order">Sort order</label>
          <input class="admin-input" type="number" id="sort_order" name="sort_order"
            value={entry.sort_order} required />
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Level</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="level_es">Level (ES) *</label>
            <input class="admin-input" type="text" id="level_es" name="level_es"
              value={entry.level_es} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="level_en">Level (EN) *</label>
            <input class="admin-input" type="text" id="level_en" name="level_en"
              value={entry.level_en} required />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Save changes</button>
      <a href="/admin/languages" class="admin-btn admin-btn--secondary">Cancel</a>
    </div>

  </form>

  <section class="danger-section" aria-label="Danger zone">
    <div class="admin-card danger-card">
      <span class="admin-section-title" style="color: var(--danger, #ef4444);">Danger Zone</span>
      <p class="danger-msg">Permanently delete this language entry. This cannot be undone.</p>
      <form action={`/admin/languages/${id}/delete`} method="POST">
        <button
          type="submit"
          class="admin-btn admin-btn--danger"
          onclick="return confirm('Delete this entry? This cannot be undone.')"
        >Delete entry</button>
      </form>
    </div>
  </section>

</AdminLayout>

<style>
  .danger-section { margin-top: 36px; max-width: 940px; }
  .danger-card { border-color: rgba(239, 68, 68, 0.25); }
  .danger-msg { font-size: 13px; color: var(--admin-muted); margin-bottom: 16px; }
</style>
