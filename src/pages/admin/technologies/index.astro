---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { data: technologies } = await supabase
  .from('technologies')
  .select('id, sort_order, name, category, level')
  .order('sort_order');
---
<AdminLayout title="Tecnologías — Admin">
  <div class="admin-page-header">
    <h1>Tecnologías</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/technologies/new" class="admin-btn admin-btn--primary">+ Nueva tecnología</a>
    </div>
  </div>

  <div class="admin-card table-card">
    {technologies?.length ? (
      <table class="list-table">
        <thead>
          <tr>
            <th>Orden</th>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Nivel</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {technologies.map((t) => (
            <tr>
              <td class="col-muted">{t.sort_order}</td>
              <td class="col-name">{t.name}</td>
              <td class="col-muted">{t.category}</td>
              <td>
                <div class="level-dots">
                  {Array.from({ length: 5 }, (_, i) => (
                    <span class:list={['dot', { filled: i < t.level }]}></span>
                  ))}
                </div>
              </td>
              <td class="col-actions">
                <a href={`/admin/technologies/${t.id}`} class="admin-btn admin-btn--secondary admin-btn--sm">Editar</a>
                <form action={`/admin/technologies/${t.id}/delete`} method="POST" class="inline-form">
                  <button
                    type="submit"
                    class="admin-btn admin-btn--danger admin-btn--sm"
                    onclick="return confirm('¿Eliminar esta tecnología?')"
                  >Eliminar</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    ) : (
      <p class="empty-state">Todavía no hay tecnologías cargadas. <a href="/admin/technologies/new" class="empty-link">Crea la primera.</a></p>
    )}
  </div>
</AdminLayout>

<style>
  .table-card { padding: 0; overflow: hidden; }

  .list-table { width: 100%; border-collapse: collapse; font-size: 14px; }

  thead th {
    text-align: left;
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--admin-muted);
    border-bottom: 1px solid var(--admin-border);
  }

  td {
    padding: 13px 16px;
    border-bottom: 1px solid var(--admin-border);
    vertical-align: middle;
  }

  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: rgba(255, 255, 255, 0.025); }
  html.light tbody tr:hover td { background: rgba(0, 0, 0, 0.025); }

  .col-muted { color: var(--admin-muted); }
  .col-name { font-weight: 500; }

  .level-dots { display: flex; gap: 4px; align-items: center; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--admin-border); }
  .dot.filled { background: var(--admin-accent); }

  .col-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    white-space: nowrap;
  }

  .inline-form { display: contents; }

  .empty-state {
    padding: 48px 28px;
    text-align: center;
    color: var(--admin-muted);
    font-size: 14px;
  }

  .empty-link {
    color: var(--admin-accent);
    text-decoration: underline;
  }
</style>
