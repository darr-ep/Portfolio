---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { id } = Astro.params;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  await supabase.from('technologies').update({
    sort_order: Number(form.get('sort_order')),
    name: form.get('name'),
    category: form.get('category'),
    icon: form.get('icon') || null,
    level: Number(form.get('level')),
  }).eq('id', id!);
  return Astro.redirect('/admin/technologies');
}

const { data: tech } = await supabase
  .from('technologies')
  .select('*')
  .eq('id', id!)
  .single();

if (!tech) {
  return Astro.redirect('/admin/technologies');
}
---
<AdminLayout title={`Edit: ${tech.name} — Admin`}>

  <div class="admin-page-header">
    <h1>Edit Technology</h1>
    <div class="admin-page-header-actions">
      <a href="/admin/technologies" class="admin-btn admin-btn--secondary">Back to list</a>
    </div>
  </div>

  <form method="POST" class="admin-form-stack">

    <div class="admin-card">
      <span class="admin-section-title">Basics</span>
      <div class="admin-fields">
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="name">Name *</label>
            <input class="admin-input" type="text" id="name" name="name"
              value={tech.name} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="sort_order">Sort order</label>
            <input class="admin-input" type="number" id="sort_order" name="sort_order"
              value={tech.sort_order} required />
          </div>
        </div>
        <div class="admin-row">
          <div class="admin-field">
            <label class="admin-label" for="category">Category *</label>
            <input class="admin-input" type="text" id="category" name="category"
              value={tech.category} required />
          </div>
          <div class="admin-field">
            <label class="admin-label" for="icon">Icon</label>
            <input class="admin-input" type="text" id="icon" name="icon"
              value={tech.icon ?? ''} />
          </div>
        </div>
      </div>
    </div>

    <div class="admin-card">
      <span class="admin-section-title">Details</span>
      <div class="admin-fields">
        <div class="admin-field">
          <label class="admin-label" for="level">Level (1-5) *</label>
          <input class="admin-input" type="number" id="level" name="level"
            min="1" max="5" value={tech.level} required />
        </div>
      </div>
    </div>

    <div class="admin-form-actions">
      <button type="submit" class="admin-btn admin-btn--primary">Save changes</button>
      <a href="/admin/technologies" class="admin-btn admin-btn--secondary">Cancel</a>
    </div>

  </form>

  <section class="danger-section" aria-label="Danger zone">
    <div class="admin-card danger-card">
      <span class="admin-section-title" style="color: var(--danger, #ef4444);">Danger Zone</span>
      <p class="danger-msg">Permanently delete this technology. This cannot be undone.</p>
      <form action={`/admin/technologies/${id}/delete`} method="POST">
        <button
          type="submit"
          class="admin-btn admin-btn--danger"
          onclick="return confirm('Delete this technology? This cannot be undone.')"
        >Delete technology</button>
      </form>
    </div>
  </section>

</AdminLayout>

<style>
  .danger-section { margin-top: 36px; max-width: 940px; }
  .danger-card { border-color: rgba(239, 68, 68, 0.25); }
  .danger-msg { font-size: 13px; color: var(--admin-muted); margin-bottom: 16px; }
</style>
