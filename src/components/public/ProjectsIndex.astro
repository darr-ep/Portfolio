---
import { supabase } from '../../lib/supabase';
import type { Project } from '../../types/database';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const isEn = lang === 'en';

const { data: projectsData } = await supabase
  .from('projects')
  .select('*')
  .order('sort_order', { ascending: true });

const FALLBACK_IMAGES = ['/assets/Proyecto 1.webp', '/assets/Proyecto 2.webp', '/assets/Proyecto 3.webp'];

const projects = (projectsData ?? []).map((p: Project, i: number) => ({
  title: isEn ? p.title_en : p.title_es,
  category: isEn ? p.category_en : p.category_es,
  description: isEn ? p.description_en : p.description_es,
  tech: p.tech ?? [],
  image: p.main_image ?? FALLBACK_IMAGES[i % FALLBACK_IMAGES.length],
  href: isEn ? `/en/projects/${p.slug}` : `/proyectos/${p.slug}`,
}));

const t = {
  back: isEn ? 'Back to home' : 'Volver al inicio',
  title: isEn ? 'WORK' : 'PROYECTOS',
  subtitle: isEn ? 'Selected projects and case studies.' : 'Proyectos y casos seleccionados.',
  view: isEn ? 'View project →' : 'Ver proyecto →',
  homeHref: isEn ? '/en/' : '/',
  countLabel: isEn ? 'projects' : 'proyectos',
};
---

<section class="work-index">
  <div class="work-container">
    <!-- Header -->
    <div class="work-header">
      <a href={t.homeHref} class="work-back" data-logo-link>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {t.back}
      </a>

      <div class="work-title-row">
        <h1 class="work-title">{t.title}</h1>
        <span class="work-count">{String(projects.length).padStart(2, '0')} {t.countLabel}</span>
      </div>
      <p class="work-subtitle">{t.subtitle}</p>
    </div>

    <!-- Grid -->
    <div class="work-grid">
      {projects.map((p, i) => (
        <a href={p.href} class="work-card" data-transition-label={p.title.toUpperCase()}>
          <div class="work-card__media">
            <img src={p.image} alt={p.title} class="work-card__img" loading="lazy" />
            <span class="work-card__num">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <div class="work-card__body">
            <span class="work-card__cat">{p.category.toUpperCase()}</span>
            <h2 class="work-card__title">{p.title.toUpperCase()}</h2>
            <p class="work-card__desc">{p.description}</p>
            <div class="work-card__tech">
              {p.tech.slice(0, 4).map((tech) => <span>{tech}</span>)}
            </div>
            <span class="work-card__link">{t.view}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work-index {
    width: 100%;
    min-height: 100vh;
    padding: 8rem 5vw 6rem;
    padding-left: calc(80px + 5vw);
    background-color: var(--bg-primary);
    transition: background-color 0.3s ease;
  }

  .work-container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* Header */
  .work-header {
    margin-bottom: 4.5rem;
  }

  .work-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-decoration: none;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    transition: color 0.3s ease;
  }

  .work-back:hover { color: var(--accent); }

  .work-title-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .work-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2.6rem, 7vw, 5.5rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--text-primary);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .work-count {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .work-subtitle {
    margin-top: 1.25rem;
    font-family: var(--font-body, sans-serif);
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.6;
  }

  /* Grid */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3.5rem 2.5rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .work-card__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background-color: var(--bg-secondary, #111);
    margin-bottom: 1.5rem;
    transition: border-color 0.3s ease;
  }

  .work-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .work-card:hover .work-card__img { transform: scale(1.05); }
  .work-card:hover .work-card__media { border-color: var(--accent); }

  .work-card__num {
    position: absolute;
    top: 1rem;
    left: 1.25rem;
    z-index: 2;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: #fff;
    mix-blend-mode: difference;
  }

  .work-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .work-card__cat {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .work-card__title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .work-card:hover .work-card__title { color: var(--accent); }

  .work-card__desc {
    font-family: var(--font-body, sans-serif);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .work-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .work-card__tech span {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.6rem;
    letter-spacing: 0.05em;
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    color: var(--text-secondary);
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .work-card__link {
    margin-top: 0.75rem;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    transition: opacity 0.3s ease;
  }

  .work-card:hover .work-card__link { opacity: 0.7; }

  /* Tablet */
  @media (max-width: 992px) {
    .work-index {
      padding-left: 5vw;
      padding-top: 6rem;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .work-index {
      padding: 5rem 1.5rem 4rem;
    }

    .work-header { margin-bottom: 3rem; }

    .work-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
