---
import { supabase } from '../../lib/supabase';
import type { Project } from '../../types/database';
import { isProjectReady, resolveCardImage } from '../../lib/projects';
import { getTechIcon } from '../../lib/tech-icons';

const { data: projectsData } = await supabase
  .from('projects')
  .select('*, project_images(slot_key, url)')
  .order('sort_order', { ascending: true });

const lang = Astro.currentLocale ?? 'es';

type ProjectWithImages = Project & { project_images?: { slot_key: string; url: string }[] };

const projects = (projectsData ?? []).map((p: ProjectWithImages, i: number) => ({
  id: p.id,
  title: lang === 'en' ? p.title_en : p.title_es,
  category: lang === 'en' ? p.category_en : p.category_es,
  description: lang === 'en' ? p.description_en : p.description_es,
  tech: p.tech ?? [],
  image: resolveCardImage(p, i),
  ready: isProjectReady(p),
  slug: p.slug,
  href: lang === 'en' ? `/en/projects/${p.slug}` : `/proyectos/${p.slug}`,
}));

const sectionTitle = lang === 'en' ? 'PROJECTS' : 'PROYECTOS';
const seeMoreLabel = lang === 'en' ? 'See more →' : 'Ver más →';
const soonLabel = lang === 'en' ? 'Coming soon' : 'Próximamente';
const moreLabel = lang === 'en' ? 'More projects' : 'Más proyectos';
const allProjectsHref = lang === 'en' ? '/en/projects' : '/proyectos';
const allProjectsLabel = lang === 'en' ? 'PROJECTS' : 'PROYECTOS';

// Landing shows a curated teaser; the full grid lives on the dedicated /proyectos page.
const featuredDesktop = projects.slice(0, 4);
const featuredMobile = projects.slice(0, 2);
---

<section id="proyectos" class="projects-section">
  <div class="container">
    <!-- Section header -->
    <div class="section-header">
      <span class="section-num">02 /</span>
      <h2 class="section-title">{sectionTitle}</h2>
      <div class="header-line"></div>
    </div>

    <!-- Split layout (desktop / tablet): 3D visualizer + interactive accordion -->
    <div class="projects-split-layout projects-featured-desktop">
      <!-- Left: 3D visualizer -->
      <div class="projects-visuals">
        <!-- Back layer (dim) -->
        <div class="visuals-layer-back">
          {featuredDesktop.map((p, i) => (
            <div class={`visual-card-back ${i === 0 ? 'pos-center' : i === 1 ? 'pos-right' : 'pos-left'}`} data-index={i}>
              <img src={p.image} alt={p.title} class="project-img" />
              <div class="project-overlay"></div>
            </div>
          ))}
        </div>

        <!-- Front layer (active/inactive opacity) -->
        <div class="visuals-layer-front">
          {featuredDesktop.map((p, i) => (
            <div class={`visual-card-front ${i === 0 ? 'pos-center' : i === 1 ? 'pos-right' : 'pos-left'}`} data-index={i}>
              <img src={p.image} alt={p.title} class="project-img" />
              <div class="project-overlay"></div>
              <span class="project-number">0{i + 1}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Interactive project list with flowing-menu hover -->
      <div class="projects-accordion">
        {featuredDesktop.map((p, i) => (
          <div class={`accordion-item ${i === 0 ? 'active' : ''} ${p.ready ? '' : 'is-soon'}`} data-index={i}>
            <a
              class="accordion-header"
              data-index={i}
              data-transition-label={p.title.toUpperCase()}
              {...(p.ready ? { href: p.href } : {})}
            >
              <span class="acc-num">0{i + 1}/</span>
              <h3 class="acc-title">{p.title.toUpperCase()}</h3>
              {p.ready ? (
                <span class="flow-marquee" aria-hidden="true">
                  <span class="flow-marquee__inner">
                    {Array.from({ length: 8 }).map(() => (
                      <span class="flow-unit">
                        <span class="flow-text">{p.title.toUpperCase()}</span>
                        <span class="flow-img" style={`background-image:url('${p.image}')`}></span>
                      </span>
                    ))}
                  </span>
                </span>
              ) : (
                <span class="soon-chip">{soonLabel}</span>
              )}
            </a>
            <div class="accordion-body">
              <div class="accordion-content">
                <div class="project-meta">
                  <span class="project-category">{p.category.toUpperCase()}</span>
                </div>
                {p.description && <p class="project-desc">{p.description}</p>}
                <div class="project-tech">
                  {p.tech.map((t) => {
                    const icon = getTechIcon(t);
                    return (
                      <span class="tech-chip" style={icon ? `--brand: #${icon.hex}` : undefined}>
                        {icon && <span class="tech-chip__icon" set:html={icon.svg} />}
                        <span>{t}</span>
                      </span>
                    );
                  })}
                </div>
                {p.ready
                  ? <a href={p.href} class="project-link" data-transition-label={p.title.toUpperCase()}>{seeMoreLabel}</a>
                  : <span class="project-link project-link--soon">{soonLabel}</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: the first projects fully expanded (no tabs), each with its own image -->
    <div class="projects-featured-mobile">
      {featuredMobile.map((p, i) => (
        <article class={`m-project ${p.ready ? '' : 'is-soon'}`}>
          {p.ready ? (
            <a href={p.href} class="m-project__media" data-transition-label={p.title.toUpperCase()}>
              <img src={p.image} alt={p.title} class="m-project__img" loading="lazy" />
              <span class="m-project__num">0{i + 1}</span>
            </a>
          ) : (
            <div class="m-project__media">
              <img src={p.image} alt={p.title} class="m-project__img" loading="lazy" />
              <span class="m-project__num">0{i + 1}</span>
              <span class="soon-chip soon-chip--overlay">{soonLabel}</span>
            </div>
          )}
          <div class="m-project__body">
            <span class="m-project__cat">{p.category.toUpperCase()}</span>
            <h3 class="m-project__title">{p.title.toUpperCase()}</h3>
            {p.description && <p class="m-project__desc">{p.description}</p>}
            <div class="m-project__tech">
              {p.tech.slice(0, 4).map((t) => {
                const icon = getTechIcon(t);
                return (
                  <span class="tech-chip" style={icon ? `--brand: #${icon.hex}` : undefined}>
                    {icon && <span class="tech-chip__icon" set:html={icon.svg} />}
                    <span>{t}</span>
                  </span>
                );
              })}
            </div>
            {p.ready
              ? <a href={p.href} class="m-project__link" data-transition-label={p.title.toUpperCase()}>{seeMoreLabel}</a>
              : <span class="m-project__link m-project__link--soon">{soonLabel}</span>}
          </div>
        </article>
      ))}
    </div>

    <!-- Gateway to the full projects page -->
    <div class="projects-more">
      <a href={allProjectsHref} class="projects-more__link" data-transition-label={allProjectsLabel}>
        <span>{moreLabel}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>


<style>
  .projects-section {
    width: 100%;
    padding: 8rem 6vw;
    padding-left: calc(80px + 6vw);
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    border-top: 1px solid var(--border-color);
    position: relative;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* Section header */
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 5rem;
  }

  .section-num {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3.5rem);
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .header-line {
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-color), transparent);
    margin-left: 2rem;
    transition: background 0.3s ease;
  }

  /* Split layout */
  .projects-split-layout {
    display: flex;
    gap: 5rem;
    width: 100%;
    /* Center the square visualizer against the taller accordion column. */
    align-items: center;
  }

  /* 3D Visualizer — fixed aspect-ratio (not viewport height) so the card shape
     is identical on every window size; the 3D stack uses % transforms that scale
     with the card, so the layout is unaffected. Square on desktop. */
  .projects-visuals {
    width: 42%;
    aspect-ratio: 1 / 1;
    position: relative;
    overflow: visible;
    perspective: 1200px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .visuals-layer-back,
  .visuals-layer-front {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    transform-style: preserve-3d;
  }

  .visuals-layer-back { z-index: 1; }
  .visuals-layer-front { z-index: 2; }

  .visual-card-back,
  .visual-card-front {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--bg-secondary, #111);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);
    transform-style: preserve-3d;
    backface-visibility: hidden;
    transition:
      transform 0.85s cubic-bezier(0.25, 1, 0.5, 1),
      background-color 0.3s ease;
  }

  /* 3D positions */
  .visual-card-back.pos-center,
  .visual-card-front.pos-center { transform: translate3d(0, 0, 0) scale(1) rotate(0deg); z-index: 5; }
  .visual-card-back.pos-left,
  .visual-card-front.pos-left   { transform: translate3d(-28%, 10%, -150px) scale(0.72) rotate(-8deg); z-index: 2; }
  .visual-card-back.pos-right,
  .visual-card-front.pos-right  { transform: translate3d(28%, 10%, -150px) scale(0.72) rotate(8deg); z-index: 2; }

  .visual-card-back { opacity: 0.22; }
  .visual-card-front {
    opacity: 0;
    transition:
      transform 0.85s cubic-bezier(0.25, 1, 0.5, 1),
      opacity 0.85s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .visual-card-front.pos-center { opacity: 1; pointer-events: auto; cursor: pointer; }

  .project-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .visual-card-front.pos-center:hover .project-img { transform: scale(1.04); }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13, 13, 15, 0.6) 0%, rgba(13, 13, 15, 0) 50%);
    z-index: 1;
  }

  .project-number {
    position: absolute;
    bottom: 1.5rem;
    right: 2rem;
    font-family: var(--font-ui);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    z-index: 2;
    line-height: 0.8;
  }

  html.light .project-number { color: rgba(0, 0, 0, 0.03); }

  /* Accordion */
  .projects-accordion {
    width: 55%;
    display: flex;
    flex-direction: column;
  }

  .accordion-item {
    border-bottom: 1px solid var(--border-color);
    transition: border-color 0.4s ease;
  }

  .accordion-item.active { border-color: var(--accent); }

  .accordion-header {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.6rem 0;
    cursor: pointer;
    user-select: none;
    outline: none;
    text-decoration: none;
    color: inherit;
  }

  /* Flowing-menu hover strip — covers the header from the cursor's entry edge */
  .flow-marquee {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--accent);
    transform: translateY(101%);
    pointer-events: none;
  }

  .flow-marquee__inner {
    display: flex;
    align-items: center;
    height: 100%;
    width: max-content;
    white-space: nowrap;
    will-change: transform;
  }

  .flow-unit {
    display: inline-flex;
    align-items: center;
    height: 100%;
    gap: 1.5rem;
    padding: 0 1.25rem;
  }

  .flow-text {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.4rem, 2.8vw, 2.2rem);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #0d0d0d;
    white-space: nowrap;
  }

  :global(html.light) .flow-text {
    color: #1d1d1f;
  }

  .flow-img {
    height: calc(100% - 4px);
    aspect-ratio: 2 / 1;
    flex-shrink: 0;
    border-radius: 999px;
    background-size: cover;
    background-position: center;
  }


  .accordion-header:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .acc-num {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.75rem;
    font-weight: bold;
    color: var(--text-muted);
    transition: color 0.4s ease;
  }

  .accordion-item.active .acc-num { color: var(--accent); }

  .acc-title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--text-muted);
    letter-spacing: -0.02em;
    transition: color 0.4s ease, transform 0.4s ease;
    text-transform: uppercase;
  }

  .accordion-item.active .acc-title {
    color: var(--text-primary);
    transform: translateX(4px);
  }

  .accordion-body {
    height: 0;
    opacity: 0;
    overflow: hidden;
    will-change: height, opacity;
  }

  .accordion-content {
    padding: 1.5rem 0 0.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-meta {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .project-desc {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 90%;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  /* Tech chips — shared style ported from the Details section (pill + brand icon). */
  .tech-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .tech-chip:hover { border-color: var(--accent); }

  /* Brand tint mixed toward the theme's text color so near-black logos stay visible. */
  .tech-chip__icon {
    color: color-mix(in srgb, var(--brand, currentColor) 72%, var(--text-primary));
  }

  /* :global() — the SVG comes from set:html (raw markup) with no scoped attribute. */
  .tech-chip__icon :global(svg) {
    display: block;
    width: 15px;
    height: 15px;
    fill: currentColor;
  }

  .project-link {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: opacity 0.3s ease;
  }

  .project-link:hover { opacity: 0.7; }

  /* Coming-soon (pending) states */
  .accordion-item.is-soon .accordion-header { cursor: default; }
  .accordion-item.is-soon .acc-title { color: var(--text-muted); }
  .accordion-item.is-soon.active .acc-title { color: var(--text-secondary); }

  .soon-chip {
    margin-left: auto;
    align-self: center;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .project-link--soon,
  .m-project__link--soon { color: var(--text-muted); cursor: default; }

  .soon-chip--overlay {
    position: absolute;
    top: 0.9rem;
    right: 1.1rem;
    z-index: 2;
    margin: 0;
    color: #fff;
    background: rgba(0, 0, 0, 0.5);
    border-color: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
  }

  /* Gateway link to the full projects page */
  .projects-more {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
  }

  .projects-more__link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.9rem 1.75rem;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    transition: color 0.3s ease, border-color 0.3s ease, gap 0.3s ease;
  }

  .projects-more__link svg { transition: transform 0.3s ease; }

  .projects-more__link:hover {
    color: var(--accent);
    border-color: var(--accent);
    gap: 1.1rem;
  }

  .projects-more__link:hover svg { transform: translateX(3px); }

  /* Mobile expanded cards — hidden on desktop, shown ≤768px */
  .projects-featured-mobile { display: none; }

  .m-project { display: flex; flex-direction: column; }

  .m-project__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background-color: var(--bg-secondary, #111);
    margin-bottom: 1.25rem;
    text-decoration: none;
  }

  .m-project__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .m-project__num {
    position: absolute;
    top: 0.9rem;
    left: 1.1rem;
    z-index: 2;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.8rem;
    color: #fff;
    mix-blend-mode: difference;
  }

  .m-project__body { display: flex; flex-direction: column; gap: 0.6rem; }

  .m-project__cat {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .m-project__title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(1.6rem, 8vw, 2.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-transform: uppercase;
  }

  .m-project__desc {
    font-family: var(--font-body, sans-serif);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .m-project__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.1rem;
  }

  .m-project__link {
    margin-top: 0.5rem;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--accent);
    text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .projects-split-layout {
      flex-direction: column;
      gap: 2.5rem;
    }

    /* Fixed aspect-ratio instead of viewport-height sizing: the card shape stays
       consistent across tablet widths (no more square-on-narrow / wide-on-wide),
       and capping the width keeps it from dominating the top of the column. */
    .projects-visuals {
      width: 100%;
      max-width: 460px;
      margin: 0 auto;
      height: auto;
      aspect-ratio: 16 / 10;
    }

    /* On touch screens the 3D side-stack only sticks out and hides the project tabs.
       Show just the active image — flat and centered — and drop the dim back layer,
       so image + tabs + the active description all fit comfortably. */
    .visuals-layer-back { display: none; }
    .visual-card-front.pos-center,
    .visual-card-front.pos-left,
    .visual-card-front.pos-right {
      transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
    }

    .projects-accordion { width: 100%; }
    .accordion-header { gap: 0.9rem; padding: 1.1rem 0; }
    .accordion-content { padding-left: 1.5rem; }
    /* No hover on touch — the flowing strip has no purpose */
    .flow-marquee { display: none; }
  }

  @media (max-width: 768px) {
    .projects-section {
      padding: 6rem 1.5rem;
    }

    .section-header { margin-bottom: 3rem; }

    /* Swap the visualizer + accordion for fully expanded cards */
    .projects-featured-desktop { display: none; }
    .projects-featured-mobile {
      display: flex;
      flex-direction: column;
      gap: 3.5rem;
    }

    .projects-more { margin-top: 3rem; }
    .projects-more__link { width: 100%; justify-content: center; }
  }
</style>
