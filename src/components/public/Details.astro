---
import { supabase } from '../../lib/supabase';
import type { Technology } from '../../types/database';
import { getTechIcon } from '../../lib/tech-icons';

const { data: techData } = await supabase
  .from('technologies')
  .select('*')
  .order('sort_order', { ascending: true });

const technologies: Technology[] = techData ?? [];

// Group by category for the grid display
const categoryMap = new Map<string, string[]>();
for (const tech of technologies) {
  const list = categoryMap.get(tech.category) ?? [];
  list.push(tech.name);
  categoryMap.set(tech.category, list);
}

const skillGroups = Array.from(categoryMap.entries()).map(([category, skills]) => ({
  category,
  skills,
}));

const lang = Astro.currentLocale ?? 'es';
const sectionTitle = lang === 'en' ? 'DETAILS' : 'DETALLES';
// Two explicit downloads regardless of the page locale: the CV exists in both
// languages and a visitor may want either one.
const cvLinks = [
  { href: '/cv.pdf', label: lang === 'en' ? 'CV (Spanish)' : 'CV (Español)' },
  { href: '/cv.pdf?lang=en', label: lang === 'en' ? 'CV (English)' : 'CV (Inglés)' },
];
---

<section id="detalles" class="details-section">
  <div class="container">
    <!-- Section header -->
    <div class="section-header">
      <span class="section-num">04 /</span>
      <h2 class="section-title">{sectionTitle}</h2>
      <div class="header-line"></div>
    </div>

    <!-- Split layout -->
    <div class="details-layout">
      <!-- Left: Philosophy -->
      <div class="details-left reveal-details-left">
        <h3 class="philosophy-title">
          CONCEPTS<br />
          <span class="text-glow">&gt; CODE</span>
        </h3>
        <p class="philosophy-text">
          {lang === 'en'
            ? 'Every detail is a design decision, not an accident. I work at the intersection of visual design and engineering, where the concept defines the experience and the code makes it inevitable.'
            : 'Cada detalle es una decisión de diseño, no un accidente. Trabajo en el cruce entre el diseño visual y la ingeniería, donde el concepto define la experiencia y el código la vuelve inevitable.'}
        </p>
        <p class="philosophy-sub">
          {lang === 'en'
            ? "I don't code to meet requirements; I code to create memorable, fluid experiences."
            : 'No programo para cumplir requisitos; programo para crear experiencias memorables y fluidas.'}
        </p>
        <div class="cv-links">
          {cvLinks.map((cv) => (
            <a href={cv.href} class="cv-link" download aria-label={cv.label}>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              {cv.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Right: Skills grouped by category as editorial rows -->
      <div class="details-right reveal-details-right">
        <div class="skills-list">
          {skillGroups.map((group) => (
            <div class="skill-group">
              <div class="skill-group__head">
                <span class="skill-category">{group.category.toUpperCase()}</span>
                <span class="skill-group__line" aria-hidden="true"></span>
              </div>
              <div class="skill-chips">
                {group.skills.map((skill) => {
                  const icon = getTechIcon(skill);
                  return (
                    <span class="skill-chip" style={icon ? `--brand: #${icon.hex}` : undefined}>
                      {icon && <span class="skill-chip__icon" set:html={icon.svg} />}
                      <span>{skill}</span>
                    </span>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>


<style>
  .details-section {
    width: 100%;
    padding: 8rem 6vw;
    padding-left: calc(80px + 6vw);
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    position: relative;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Section header */
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .section-num {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3.5rem);
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .header-line {
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-color), transparent);
    margin-left: 2rem;
    transition: background 0.3s ease;
  }

  /* Split layout */
  .details-layout {
    display: flex;
    gap: 5vw;
    align-items: flex-start;
  }

  .details-left {
    width: 45%;
    will-change: opacity, transform;
  }

  .details-right {
    width: 55%;
    will-change: opacity, transform;
  }

  /* Philosophy */
  .philosophy-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 2.5rem;
    transition: color 0.3s ease;
  }

  .text-glow {
    color: transparent;
    -webkit-text-stroke: 1px var(--text-primary);
    transition: -webkit-text-stroke 0.3s ease;
  }

  .philosophy-text {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    transition: color 0.3s ease;
  }

  .philosophy-sub {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.8rem;
    color: var(--accent-strong);
    line-height: 1.6;
    border-left: 2px solid var(--accent-strong);
    padding-left: 1.2rem;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  /* Skills grouped as editorial rows (no boxes) */
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .skill-group__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.1rem;
  }

  /* Fading divider — reuses the section-header line motif. */
  .skill-group__line {
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-color), transparent);
    transition: background 0.3s ease;
  }

  .skill-category {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    white-space: nowrap;
    transition: color 0.3s ease;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .skill-chip:hover { border-color: var(--accent); }

  /* Brand tint mixed toward the theme's text color so near-black logos
     (Next.js, Three.js) stay visible on the dark background. */
  .skill-chip__icon {
    color: color-mix(in srgb, var(--brand, currentColor) 72%, var(--text-primary));
  }

  /* :global() — the SVG comes from set:html (raw markup), so it never carries Astro's
     scoped-style attribute; without :global() this rule silently never matches. */
  .skill-chip__icon :global(svg) {
    display: block;
    width: 15px;
    height: 15px;
    fill: currentColor;
  }

  .cv-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .cv-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-decoration: none;
    border: 1px solid var(--border-color);
    padding: 0.55rem 1.25rem;
    border-radius: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .cv-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Responsive */
  @media (max-width: 992px) {
    .details-layout {
      flex-direction: column;
      gap: 5rem;
    }

    .details-left,
    .details-right { width: 100%; }
  }

  @media (max-width: 768px) {
    .details-section {
      padding: 5rem 1.5rem;
    }

    .skills-list { gap: 2rem; }
  }
</style>
