---
import { getLocaleAlternates } from '../../i18n/routes';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  url?: string;
  type?: 'website' | 'article';
  /** JSON-LD graph nodes to emit, built with src/lib/schema.ts. */
  schemas?: Record<string, unknown>[];
}

const {
  title = 'Edson Pedraza — Full Stack Developer',
  description = 'Portfolio personal de Edson Pedraza. Full Stack Developer especializado en crear experiencias web y aplicaciones interactivas.',
  image = '/assets/og-image.png',
  lang = 'es',
  url,
  type = 'website',
  schemas = [],
} = Astro.props;

const siteUrl = 'https://edsonpedraza.com';
const path = url ?? '/';
const canonicalUrl = `${siteUrl}${path}`;
const ogImage = image?.startsWith('http') ? image : `${siteUrl}${image}`;

// Per-page hreflang: map the current path to its equivalent in each locale so
// alternates point to the real sibling page (not always the home). x-default
// resolves to the ES version, the default locale.
const { es: esPath, en: enPath } = getLocaleAlternates(path);
const esUrl = `${siteUrl}${esPath}`;
const enUrl = `${siteUrl}${enPath}`;
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- hreflang alternates -->
<link rel="alternate" hreflang="es" href={esUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={esUrl} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={lang === 'es' ? 'es_MX' : 'en_US'} />
<meta property="og:site_name" content="Edson Pedraza" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
