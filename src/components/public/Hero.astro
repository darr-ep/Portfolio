---
import PixelBlast from '../islands/PixelBlast.tsx';
import SpotifyWidget from '../islands/SpotifyWidget.tsx';
import { supabase } from '../../lib/supabase';

const lang = Astro.currentLocale ?? 'es';
const scrollLabel = lang === 'en' ? 'SCROLL TO EXPLORE' : 'DESLIZA PARA EXPLORAR';
const scrollAriaLabel = lang === 'en' ? 'Go to projects' : 'Ir a proyectos';
const wipLabel = lang === 'en' ? 'SITE IN DEVELOPMENT' : 'SITIO EN DESARROLLO';

// Availability status is CMS-driven (profile table). select('*') stays safe if the
// migration hasn't run yet — the fields are simply absent and the fallbacks apply.
const { data: profile } = await supabase.from('profile').select('*').single();
const available = profile?.available_for_work ?? true;
const statusText =
  (lang === 'en' ? profile?.status_en : profile?.status_es) ||
  (lang === 'en' ? 'AVAILABLE FOR WORK' : 'DISPONIBLE PARA TRABAJAR');
---

<section class="hero">
  <!-- Mobile hero bar: logo + menu trigger — embedded in hero, not fixed -->
  <div class="hero-mobile-bar">
    <a href="/" class="hmb-logo" data-logo-link aria-label="Edson Pedraza — home">
      <img src="/assets/Logo-Dark.webp" alt="Edson Pedraza" class="hmb-logo-img" draggable="false" />
    </a>
    <button class="hmb-menu" id="hero-menu-trigger" type="button" aria-label="Open navigation menu">
      MENU
    </button>
  </div>

  <!-- Left side: 60% -->
  <div class="hero-left">
    <!-- Background watermark -->
    <div class="watermark" aria-hidden="true">01</div>

    <!-- Header block: name + status + spotify stacked together -->
    <div class="header-block">
      <div class="header-name">
        <span class="sub-name">EDSON PEDRAZA</span>

        <div class="status-ticker">
          <span class={`ticker-dot ${available ? '' : 'is-busy'}`} aria-hidden="true"></span>
          <span class="ticker-text">STATUS: {statusText}</span>
          <span class="ticker-divider" aria-hidden="true">/</span>
          <span id="live-time" class="ticker-time">00:00:00 LOCAL</span>
          <span class="ticker-divider" aria-hidden="true">/</span>
          <span class="ticker-wip">{wipLabel}</span>
        </div>
      </div>

      <div class="spotify-slot">
        <SpotifyWidget client:only="react" />
      </div>
    </div>

    <!-- Main title -->
    <div class="title-container">
      <h1 class="hero-title">
        <span class="title-line"><span class="title-inner">CODE INTO —</span></span>
        <span class="title-line"><span class="title-inner text-serif">experience</span></span>
      </h1>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-explore">
      <span class="scroll-text">{scrollLabel}</span>
      <a href="#proyectos" class="scroll-btn" aria-label={scrollAriaLabel}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <polyline points="19 12 12 19 5 12"></polyline>
        </svg>
      </a>
    </div>
  </div>

  <!-- Right side: 40% -->
  <div class="hero-right">
    <div class="image-container">
      <!-- Layer 1: Background image -->
      <img
        src="/assets/Fondo-Imagen.webp"
        alt="Background portrait"
        class="hero-img img-bg"
      />

      <!-- Layer 2: PixelBlast canvas. client:media gates the ~57KB OGL WebGL
           island: its JS is never downloaded and no WebGL context is created unless
           the viewport is desktop-width AND the user allows motion. On mobile or with
           prefers-reduced-motion the island simply never hydrates. -->
      <div class="pixelblast-wrap">
        <PixelBlast
          client:media="(min-width: 769px) and (prefers-reduced-motion: no-preference)"
          color="#e3a857"
          transparent={true}
          enableRipples={true}
          variant="circle"
          edgeFade={0.3}
          pixelSize={5}
          style={{ position: 'absolute', inset: 0, width: '100%', height: '100%', zIndex: 2 }}
        />
      </div>

      <!-- Layer 3: Foreground image -->
      <img
        src="/assets/Frente-Imagen.webp"
        alt="Edson Pedraza"
        class="hero-img img-fg"
      />
    </div>
  </div>
</section>

<script>
  // Live clock
  let clockInterval: ReturnType<typeof setInterval> | undefined;
  function updateTime() {
    const el = document.getElementById('live-time');
    if (el) {
      const now = new Date();
      el.innerText = `${now.toLocaleTimeString('es-AR', { hour12: false })} LOCAL`;
    }
  }
  function startClock() {
    updateTime();
    clearInterval(clockInterval);
    clockInterval = setInterval(updateTime, 1000);
  }
  // This module runs once, but the listeners persist on document. astro:page-load fires on the
  // initial load AND after every ClientRouter navigation, so coming back to the landing restarts
  // the clock (the fresh DOM ships the SSR "00:00:00" placeholder otherwise).
  startClock();
  document.addEventListener('astro:page-load', startClock);
  document.addEventListener('astro:before-swap', () => clearInterval(clockInterval));

  // Scroll button — delegates smooth scroll to Lenis if available
  const scrollBtn = document.querySelector('.scroll-btn');
  scrollBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    const target = document.querySelector('#proyectos');
    if (target && (window as any).lenis) {
      (window as any).lenis.scrollTo(target, {
        duration: 2.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });
    } else if (target) {
      target.scrollIntoView({ behavior: 'smooth' });
    }
  });

  // Hero menu trigger — opens mobile StaggeredMenu from within the hero
  function setupHeroMenuTrigger() {
    const trigger = document.getElementById('hero-menu-trigger');
    if (!trigger) return;
    trigger.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('hero:menu-open'));
    });
  }
  setupHeroMenuTrigger();
  document.addEventListener('astro:page-load', setupHeroMenuTrigger);
</script>

<style>
  .hero {
    display: grid;
    grid-template-columns: 60% 40%;
    min-height: 100vh;
    width: 100%;
    padding-left: 80px;
    background-color: var(--bg-primary);
    overflow: hidden;
    position: relative;
    border-bottom: 1px solid var(--border-color);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  /* Left */
  .hero-left {
    padding: 5rem 5vw 4rem 5vw;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 10;
  }

  .watermark {
    position: absolute;
    bottom: 0;
    right: 30px;
    font-family: var(--font-ui);
    font-size: 20vw;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.012);
    line-height: 0.75;
    pointer-events: none;
    user-select: none;
    z-index: -1;
  }

  html.light .watermark {
    color: rgba(0, 0, 0, 0.03);
  }

  .header-name {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .sub-name {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    color: var(--text-muted);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .status-ticker {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  .ticker-wip {
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .ticker-dot {
    width: 6px;
    height: 6px;
    background-color: var(--success, #0b9b3b);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 8px var(--success, #0b9b3b);
    animation: pulse 2s infinite ease-in-out;
  }

  /* Not available: solid red, no pulse. */
  .ticker-dot.is-busy {
    background-color: var(--danger, #ef4444);
    box-shadow: 0 0 8px var(--danger, #ef4444);
    animation: none;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  .ticker-divider { opacity: 0.5; }

  .ticker-time {
    color: var(--text-secondary);
    transition: color 0.3s ease;
  }

  .header-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    /* Anchor for the absolutely-positioned Spotify slot below the name. */
    position: relative;
  }

  /* The Spotify widget hangs below the name but is OUT of the flex flow, so when it
     transitions to its floating (fixed) state nothing reflows in the hero. */
  .spotify-slot {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0.85rem;
  }

  .title-container {
    position: relative;
    z-index: 5;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-weight: 100;
    text-transform: uppercase;
    font-size: clamp(3rem, 7.2vw, 7.8rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    display: flex;
    flex-direction: column;
    transition: color 0.3s ease;
  }

  .title-line {
    overflow: hidden;
    display: inline-block;
  }

  .title-line:last-child {
    padding-bottom: 0.2em;
  }

  .title-inner {
    display: inline-block;
  }

  .text-serif {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
    color: var(--accent);
    text-transform: lowercase;
    font-size: clamp(3.5rem, 8.6vw, 9.4rem);
    line-height: 0.8;
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
  }

  .scroll-explore {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .scroll-text {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    transition: color 0.3s ease;
  }

  .scroll-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-primary);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .scroll-btn:hover {
    background-color: var(--text-primary);
    color: var(--bg-primary);
    border-color: var(--text-primary);
    transform: translateY(3px);
  }

  /* Right */
  .hero-right {
    position: relative;
    overflow: hidden;
    background-color: var(--bg-secondary, #111);
    transition: background-color 0.3s ease;
  }

  .image-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hero-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .img-bg {
    z-index: 1;
    filter: brightness(0.85) contrast(1.1);
    object-position: center;
  }

  .img-fg {
    z-index: 3;
    pointer-events: none;
    object-position: center;
  }

  .pixelblast-wrap {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  @media (max-width: 768px) {
    .pixelblast-wrap {
      display: none;
    }
  }

  /* Responsive — full-bleed image background with overlaid text */
  @media (max-width: 768px) {
    .hero {
      display: block;
      position: relative;
      padding-left: 0;
      min-height: 100vh;
      min-height: 100dvh;
      overflow: hidden;
    }

    /* Image layers become the full hero background */
    .hero-right {
      position: absolute;
      inset: 0;
      height: 100%;
      z-index: 0;
      /* Let touches scroll the page through to the document, and stop the
         PixelBlast canvas from capturing them (it would block vertical scroll). */
      pointer-events: none;
    }

    /* Bias the portrait toward the top so the face stays visible above the title */
    .img-fg {
      object-position: top center;
    }

    /* Text overlays the image; the gradient scrim keeps it readable over the photo */
    .hero-left {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      min-height: 100dvh;
      /* extra top padding clears the transparent overlay header (logo + menu button) */
      padding: 5rem 1.5rem 2.75rem;
      gap: 1.5rem;
      justify-content: space-between;
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.72) 0%,
        rgba(0, 0, 0, 0.35) 30%,
        rgba(0, 0, 0, 0.45) 62%,
        rgba(0, 0, 0, 0.9) 100%
      );
    }

    /* Force light text over the photo regardless of the active theme */
    .sub-name,
    .status-ticker,
    .ticker-text,
    .ticker-time,
    .scroll-text {
      color: rgba(255, 255, 255, 0.85) !important;
    }

    .hero-title {
      color: #fff;
      font-size: clamp(2.6rem, 13vw, 4rem);
      line-height: 0.9;
      text-shadow: 0 2px 24px rgba(0, 0, 0, 0.55);
    }

    .text-serif {
      /* keep the gold accent — it pops on the dark scrim */
      font-size: clamp(3rem, 15vw, 4.6rem);
      text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
    }

    .scroll-btn {
      color: #fff;
      border-color: rgba(255, 255, 255, 0.4);
    }

    .scroll-btn:hover {
      background-color: #fff;
      color: #000;
      border-color: #fff;
    }

    .header-block {
      gap: 1rem;
    }

    .header-name {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }

    .scroll-explore {
      gap: 1rem;
    }

    /* The giant "01" watermark only clutters the small screen */
    .watermark {
      display: none;
    }
  }

  /* Tablet / small desktop (769–1000px): the 60/40 split makes the portrait too
     thin (a sliver), so the hero goes full-bleed — image behind, text overlaid —
     while the desktop sidebar stays. The image spans the full width (under the
     sidebar too); Sidebar.astro drops its background in this same range so the
     photo bleeds under the nav instead of the left edge reading as a black bar. */
  @media (min-width: 769px) and (max-width: 1000px) {
    .hero {
      grid-template-columns: 1fr;
      padding-left: 0;
    }

    .hero-right {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* Bias the portrait toward the top so the face clears the title. */
    .img-fg {
      object-position: top center;
    }

    .hero-left {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      /* clear the 80px sidebar on the left; 5rem/4rem matches the sidebar rhythm */
      padding: 5rem 3rem 4rem calc(80px + 2.5rem);
      justify-content: space-between;
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.72) 0%,
        rgba(0, 0, 0, 0.35) 30%,
        rgba(0, 0, 0, 0.45) 62%,
        rgba(0, 0, 0, 0.9) 100%
      );
    }

    /* Force light text over the photo regardless of the active theme. */
    .sub-name,
    .status-ticker,
    .ticker-text,
    .ticker-time,
    .scroll-text {
      color: rgba(255, 255, 255, 0.85) !important;
    }

    .hero-title {
      color: #fff;
      font-size: clamp(3rem, 9vw, 5rem);
      line-height: 0.9;
      text-shadow: 0 2px 24px rgba(0, 0, 0, 0.55);
    }

    .text-serif {
      font-size: clamp(3.4rem, 10vw, 5.6rem);
      text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
    }

    .scroll-btn {
      color: #fff;
      border-color: rgba(255, 255, 255, 0.4);
    }

    .scroll-btn:hover {
      background-color: #fff;
      color: #000;
      border-color: #fff;
    }

    .watermark {
      display: none;
    }
  }

  /* Mobile hero bar — hidden on desktop */
  .hero-mobile-bar {
    display: none;
  }

  @media (max-width: 768px) {
    .hero-mobile-bar {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 1.4rem;
      pointer-events: none;
    }

    .hero-mobile-bar > * {
      pointer-events: auto;
    }

    .hmb-logo {
      display: flex;
      align-items: center;
      text-decoration: none;
      user-select: none;
    }

    .hmb-logo-img {
      display: block;
      height: 30px;
      width: auto;
      object-fit: contain;
    }

    .hmb-menu {
      font-family: var(--font-ui);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.9);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem 0;
    }

    .hmb-menu:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
  }

  /* Very small phones — keep the title on a single line per row */
  @media (max-width: 380px) {
    .hero-title {
      font-size: clamp(2.2rem, 12vw, 2.8rem);
    }

    .text-serif {
      font-size: clamp(2.6rem, 14vw, 3.4rem);
    }
  }
</style>
