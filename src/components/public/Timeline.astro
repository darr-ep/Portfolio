---
import { supabase } from '../../lib/supabase';
import type { TimelineEntry } from '../../types/database';
import { AceternityTimeline } from '../islands/AceternityTimeline';

const { data: timelineData } = await supabase
  .from('timeline')
  .select('*')
  .order('sort_order', { ascending: true });

const lang = Astro.currentLocale ?? 'es';
const sectionTitle = lang === 'en' ? 'EXPERIENCE' : 'TRAYECTORIA';

const entries = (timelineData ?? []).map((t: TimelineEntry) => ({
  period: t.year,
  company: t.company,
  role: lang === 'en' ? t.role_en : t.role_es,
  description: lang === 'en' ? t.description_en : t.description_es,
  entry_type: t.entry_type ?? 'work',
}));
---

<section id="trayectoria" class="timeline">
  <div class="timeline-container">
    <div class="section-header">
      <span class="section-num">03 /</span>
      <h2 class="section-title">{sectionTitle}</h2>
      <div class="header-line"></div>
    </div>

    <AceternityTimeline data={entries} lang={lang} client:visible />
  </div>
</section>

<style>
  .timeline {
    width: 100%;
    padding: 8rem 6vw;
    padding-left: calc(80px + 6vw);
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .timeline-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .section-num {
    font-family: var(--font-mono, 'Courier New', monospace);
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3.5rem);
    letter-spacing: -0.02em;
    color: var(--text-primary);
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .header-line {
    flex-grow: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-color), transparent);
    margin-left: 2rem;
    transition: background 0.3s ease;
  }

  @media (max-width: 768px) {
    .timeline {
      padding: 5rem 1.5rem;
    }
  }
</style>
